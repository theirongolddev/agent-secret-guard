{
  "hooks": {
    "afterAgentResponse": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-after-agent-response",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "afterAgentThought": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-after-agent-thought",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "afterFileEdit": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-after-file-edit",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "afterMCPExecution": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-after-mcp",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "afterShellExecution": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-after-shell",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-before-mcp",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "beforeReadFile": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-before-read",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "beforeShellExecution": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-before-shell",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-before-prompt",
        "failClosed": false,
        "timeout": 2
      }
    ],
    "postToolUse": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-posttooluse",
        "failClosed": false,
        "matcher": ".*",
        "timeout": 2
      }
    ],
    "preToolUse": [
      {
        "command": "{{ASG_HOME}}/.local/bin/asg-cursor-pretooluse",
        "failClosed": false,
        "matcher": ".*",
        "timeout": 2
      }
    ]
  },
  "version": 1
}
