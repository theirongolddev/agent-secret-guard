{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "{{ASG_HOME}}/.local/bin/secret-scan",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "{{ASG_HOME}}/.local/bin/cmd-leak-guard",
            "type": "command"
          },
          {
            "command": "{{ASG_HOME}}/.local/bin/secret-wrap",
            "type": "command"
          },
          {
            "command": "{{ASG_HOME}}/.local/bin/infisical-guard",
            "type": "command"
          },
          {
            "command": "{{ASG_HOME}}/.local/bin/secret-push-guard",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "{{ASG_HOME}}/.local/bin/file-leak-guard",
            "type": "command"
          }
        ],
        "matcher": "Read"
      },
      {
        "hooks": [
          {
            "command": "{{ASG_HOME}}/.local/bin/secret-url-guard",
            "type": "command"
          }
        ],
        "matcher": "WebFetch|WebSearch"
      },
      {
        "hooks": [
          {
            "command": "{{ASG_HOME}}/.local/bin/secret-mcp-guard",
            "type": "command"
          }
        ],
        "matcher": "mcp__.*"
      }
    ]
  }
}
