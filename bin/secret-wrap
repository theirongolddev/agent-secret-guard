#!/bin/bash
# Compatibility adapter.
#
# Historical versions rewrote Bash commands to append a redaction pipe. That
# is unsafe because the rewritten command can itself contain and log literal
# secrets. This adapter now only scans the command text and denies when a
# credible secret is present.
set -euo pipefail
. "{{ASG_HOME}}/.local/bin/asg-hook-lib"
if OUTPUT=$("{{ASG_HOME}}/.local/bin/asg-fast" claude-pre --surface bash-command "$@" 2>/dev/null); then
  printf '%s\n' "$OUTPUT"
  exit 0
fi
asg_claude_pretool_fail_closed claude
