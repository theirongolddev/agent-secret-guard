        "Gitleaks documents the Pulumi token prefix as pul-.",
        "Atlassian docs say API tokens authenticate Jira and Confluence REST API calls.",
        "Docs use me@example.com:my-api-token as the Atlassian curl placeholder.",
        "Scanner references show Atlassian scoped API tokens can start with ATATT3xFfGF0....",
        synthetic_token("Docs show Postman keys begin with ", "P", "MAK-", "..."),
        "Docs show CO_API_KEY=YOUR_API_KEY for Cohere.",
    ):
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=sample)
        assert_true(proc.returncode == 0, f"provider expansion false-positive: {sample.split()[0]}")


def test_http_header_detection() -> None:
    expected = {
        "SENSITIVE_HTTP_HEADER": f"X-API-Key: {CANARIES['http_header']}",
        "HTTP_COOKIE_SECRET": f"Cookie: session={CANARIES['http_header']}; theme=dark",
        "HTTP_COOKIE_SECRET:set": f"Set-Cookie: __Host-session={CANARIES['http_header']}; Path=/; Secure; HttpOnly",
        "AUTH_HEADER": "Authorization: Bearer abcdefghijklmnopqrstuvwxyz123456",
        "AUTH_HEADER:toml": "Authorization = \"Bearer abcdefghijklmnopqrstuvwxyz123456\"",
        "AUTH_HEADER:json": "{\"Authorization\":\"Bearer abcdefghijklmnopqrstuvwxyz123456\"}",
    }
    for expected_kind, sample in expected.items():
        result = json_scan(sample)
        kind = expected_kind.split(":", 1)[0]
        assert_true(result["count"] == 1, f"{expected_kind} sample produced unexpected finding count")
        assert_true(result["findings"][0]["kind"] == kind, f"{expected_kind} sample has wrong kind")

    for sample in (
        "X-Request-ID: abcdefghijklmnopqrstuvwxyz123456",
        "Cookie: theme=dark; locale=en-US",
        "Set-Cookie: theme=dark; Path=/; SameSite=Lax",
        "X-API-Key: ${API_KEY}",
    ):
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=sample)
        assert_true(proc.returncode == 0, f"HTTP header false-positive: {sample.split(':', 1)[0]}")


def test_joined_literal_detection() -> None:
    secret_exprs = [
        'const apiKey = "sk-" + "proj-" + "abcdefghijklmnopqrstuvwxyz123456"',
        'const apiKey = ["sk-", "proj-", "abcdefghijklmnopqrstuvwxyz123456"].join("")',
        'api_key = "".join(["sk-", "proj-", "abcdefghijklmnopqrstuvwxyz123456"])',
        'OPENAI_API_KEY="sk-""proj-""abcdefghijklmnopqrstuvwxyz123456"',
    ]
    for secret_expr in secret_exprs:
        result = json_scan(secret_expr)
        assert_true(result["count"] == 1, "joined literal secret was missed")
        assert_true(result["findings"][0]["kind"] == "OBFUSCATED_SECRET_LITERAL", "joined literal secret has wrong kind")

        proc = run([str(BIN), "redact"], input_text=secret_expr)
        assert_true(proc.returncode == 0, f"joined literal redact failed: {proc.stderr}")
        assert_true("[REDACTED:OBFUSCATED_SECRET_LITERAL]" in proc.stdout, "joined literal was not redacted")
        assert_true("sk-" not in proc.stdout and "proj-" not in proc.stdout, "joined literal fragments leaked")

    benign_exprs = [
        'const path = "./.claude-home/" + "plugins/cache/" + "AGENTS.md"',
        'const path = ["./.claude-home/", "plugins/cache/", "AGENTS.md"].join("")',
        'export ASSET_PATH="./.claude-home/""plugins/cache/""AGENTS.md"',
    ]
    for benign in benign_exprs:
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
        assert_true(proc.returncode == 0, "joined path literal was falsely detected")


def test_static_string_dataflow_detection() -> None:
    secret_exprs = [
        'const a = "sk-";\nconst b = "proj-";\nconst c = "abcdefghijklmnopqrstuvwxyz123456";\nconst apiKey = a + b + c;\n',
        'const a = "sk-";\nconst b = "proj-";\nconst c = "abcdefghijklmnopqrstuvwxyz123456";\nconst apiKey = [a, b, c].join("");\n',
        'a = "sk-"\nb = "proj-"\nc = "abcdefghijklmnopqrstuvwxyz123456"\napi_key = a + b + c\n',
    ]
    for secret_expr in secret_exprs:
        result = json_scan(secret_expr)
        kinds = [finding["kind"] for finding in result["findings"]]
        assert_true("OBFUSCATED_SECRET_LITERAL" in kinds, "static string dataflow secret was missed")

        proc = run([str(BIN), "redact"], input_text=secret_expr)
        assert_true(proc.returncode == 0, f"static dataflow redact failed: {proc.stderr}")
        assert_true("[REDACTED:OBFUSCATED_SECRET_LITERAL]" in proc.stdout, "static dataflow was not redacted")
        assert_true("sk-" not in proc.stdout and "proj-" not in proc.stdout, "static dataflow fragments leaked")
        assert_true("abcdefghijklmnopqrstuvwxyz123456" not in proc.stdout, "static dataflow suffix leaked")

    benign_exprs = [
        'const a = "./.claude-home/";\nconst b = "plugins/cache/";\nconst c = "AGENTS.md";\nconst path = a + b + c;\n',
        'const a = "./.claude-home/";\nconst b = "plugins/cache/";\nconst c = "AGENTS.md";\nconst path = [a, b, c].join("");\n',
    ]
    for benign in benign_exprs:
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
        assert_true(proc.returncode == 0, "static path dataflow was falsely detected")


def test_multiline_reconstruction_detection() -> None:
    secret_exprs = [
        'OPENAI_API_KEY=sk-\\\nproj-\\\nabcdefghijklmnopqrstuvwxyz123456',
        'api_key: |\n  sk-\n  proj-\n  abcdefghijklmnopqrstuvwxyz123456\n',
        'api_key: >\n  sk-\n  proj-\n  abcdefghijklmnopqrstuvwxyz123456\n',
    ]
    for secret_expr in secret_exprs:
        result = json_scan(secret_expr)
        assert_true(result["count"] == 1, "multiline reconstructed secret was missed")
        assert_true(result["findings"][0]["kind"] == "OBFUSCATED_SECRET_LITERAL", "multiline secret has wrong kind")

        proc = run([str(BIN), "redact"], input_text=secret_expr)
        assert_true(proc.returncode == 0, f"multiline redact failed: {proc.stderr}")
        assert_true("[REDACTED:OBFUSCATED_SECRET_LITERAL]" in proc.stdout, "multiline secret was not redacted")
        assert_true("sk-" not in proc.stdout and "proj-" not in proc.stdout, "multiline secret fragments leaked")

    benign_exprs = [
        'ASSET_PATH=./.claude-home/\\\nplugins/cache/\\\nAGENTS.md',
        'description: |\n  Set Sentry vars scoped to Preview\n  VITE_PUBLIC_SENTRY_ENVIRONMENT\n',
        'asset_path: |\n  ./.claude-home/\n  plugins/cache/\n  AGENTS.md\n',
    ]
    for benign in benign_exprs:
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
        assert_true(proc.returncode == 0, "benign multiline content was falsely detected")


def test_escaped_sequence_reconstruction_detection() -> None:
    samples = [
        ("hex", escaped_hex(CANARIES["openai"])),
        ("unicode", escaped_unicode(CANARIES["openai"])),
        ("json-escaped-hex", escaped_hex(CANARIES["openai"]).replace("\\", "\\\\")),
    ]
    for label, sample in samples:
        result = json_scan(sample)
        assert_true(result["count"] == 1, f"{label} escaped secret was missed")
        assert_true(result["findings"][0]["kind"] == "ENCODED_SECRET_ESCAPE", f"{label} escaped secret has wrong kind")

        proc = run([str(BIN), "redact"], input_text=sample)
        assert_true(proc.returncode == 0, f"{label} escaped redact failed: {proc.stderr}")
        assert_true("[REDACTED:ENCODED_SECRET_ESCAPE]" in proc.stdout, f"{label} escaped secret was not redacted")
        assert_true("\\x73" not in proc.stdout and "\\u0073" not in proc.stdout, f"{label} escaped prefix leaked")

    benign = "\\x2e\\x2f\\x2e\\x63\\x6c\\x61\\x75\\x64\\x65\\x2d\\x68\\x6f\\x6d\\x65\\x2f\\x41\\x47\\x45\\x4e\\x54\\x53\\x2e\\x6d\\x64"
    proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
    assert_true(proc.returncode == 0, "benign escaped path was falsely detected")


def test_encoded_text_reconstruction_detection() -> None:
    samples = [
        ("html-decimal", CANARIES["openai"].replace("-", "&#45;"), "ENCODED_SECRET_HTML_ENTITY"),
        ("html-hex", CANARIES["openai"].replace("-", "&#x2d;"), "ENCODED_SECRET_HTML_ENTITY"),
        ("percent", percent_encoded(CANARIES["openai"]), "ENCODED_SECRET_PERCENT"),
        ("hex", CANARIES["openai"].encode().hex(), "ENCODED_SECRET_HEX"),
    ]
    for label, sample, kind in samples:
        result = json_scan(sample)
        assert_true(result["count"] == 1, f"{label} encoded secret was missed")
        assert_true(result["findings"][0]["kind"] == kind, f"{label} encoded secret has wrong kind")

        proc = run([str(BIN), "redact"], input_text=sample)
        assert_true(proc.returncode == 0, f"{label} encoded redact failed: {proc.stderr}")
        assert_true(f"[REDACTED:{kind}]" in proc.stdout, f"{label} encoded secret was not redacted")

    benign_samples = [
        "Use &#45; as an HTML hyphen entity in docs.",
        "Path &#x2f;Users&#x2f;example&#x2f;project is safe.",
        "Percent encoded path %2FUsers%2Fexample%2Fproject is safe.",
        "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "0123456789abcdef0123456789abcdef01234567",
    ]
    for benign in benign_samples:
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
        assert_true(proc.returncode == 0, "benign encoded text was falsely detected")


