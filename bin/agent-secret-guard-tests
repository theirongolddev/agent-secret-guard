        "Cookie: theme=dark; locale=en-US",
        "Set-Cookie: theme=dark; Path=/; SameSite=Lax",
        "DATABASE_URL='sqlite+aiosqlite:///./storage.sqlite3' uv run pytest",
        "env | cut -d= -f1 | grep -x DATABASE_URL",
        "cat > .env <<'EOF'\nHTTP_BEARER_TOKEN=\nHTTP_HOST=0.0.0.0\nHTTP_PORT=8765\nHTTP_ALLOW_LOCALHOST_UNAUTHENTICATED=true\n# AUTH token comment\nEOF",
        "const token = process.env.API_TOKEN",
        "url https://example.test/callback?state=abcdefghijklmnop",
        "url https://example.test/callback?state=e8ada1f5-c29f-4c79-ad11-7a78ce7dc10f",
        "url https://example.test?apiKey=harvest21-auth-forms-isloading-fix",
        "password = changeme",
        "api_key = ${API_KEY}",
        "{\"apiKey\":\"abcdefghijklmnop\"}",
        "{\"clientSecret\":\"changeme\"}",
        "{\"accessToken\":\"process.env.ACCESS_TOKEN\"}",
        "hf_readme placeholder hf_your_token_here",
        "vca_short placeholder vca_abc123",
        "cfut_short placeholder cfut_abc123",
        "lin_api_docs placeholder lin_api_your_key_here",
        "ntn_docs placeholder ntn_your_token_here",
        "sntrys_docs placeholder sntrys_YOUR_TOKEN_HERE",
        "anthropic docs placeholder sk-ant-api03-your-key-here",
        "openai docs placeholder sk-admin-your-key-here",
        "openrouter docs placeholder sk-or-v1-...",
        "perplexity docs placeholder pplx-1234567890abcdef",
        "replicate docs placeholder r8_...",
        "cohere docs placeholder CO_API_KEY=YOUR_API_KEY",
        "pypi short placeholder pypi-abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMN",
        "docker docs mention dckr_pat_docs_placeholder",
        "resend docs mention re_xxxxxxxxx as a placeholder",
        "Mailchimp docs mention mailchimp_your_api_key_here as a placeholder",
        "Telegram docs use 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11 as an example token.",
        "Square docs mention sq0atp-placeholder and sq0csp-placeholder as token-shaped placeholders",
        f"Supabase publishable keys are public identifiers: {CANARIES['supabase_publishable']}",
        synthetic_token('Twi', 'lio', ' re', 'sou', 'rce', ' SI', 'Ds ', 'are', ' id', 'ent', 'ifi', 'ers', ': A', 'C12', '345', '678', '90a', 'bcd', 'ef1', '234', '567', '890', 'abc', 'def', ' an', 'd S', 'K12', '345', '678', '90a', 'bcd', 'ef1', '234', '567', '890', 'abc', 'def'),
        VCS_FALSE_POSITIVE_SAMPLE,
        BR_LIST_SAMPLE,
        PATH_LISTING_SAMPLE,
        'const path = "./.claude-home/" + "plugins/cache/" + "AGENTS.md"',
        'const path = ["./.claude-home/", "plugins/cache/", "AGENTS.md"].join("")',
        'export ASSET_PATH="./.claude-home/""plugins/cache/""AGENTS.md"',
        'const a = "./.claude-home/";\nconst b = "plugins/cache/";\nconst c = "AGENTS.md";\nconst path = a + b + c;',
        'const a = "./.claude-home/";\nconst b = "plugins/cache/";\nconst c = "AGENTS.md";\nconst path = [a, b, c].join("");',
        'ASSET_PATH=./.claude-home/\\\nplugins/cache/\\\nAGENTS.md',
        'description: |\n  Set Sentry vars scoped to Preview\n  VITE_PUBLIC_SENTRY_ENVIRONMENT\n',
        'asset_path: |\n  ./.claude-home/\n  plugins/cache/\n  AGENTS.md\n',
        'const placeholder = "sk-" + "placeholder"',
        "normal sentence with no credential material",
        "base64 benign aGVsbG8td29ybGQtdGhpcy1pcy1ub3QtYS1zZWNyZXQ",
        f"double base64 benign {CANARIES['base64_benign_double']}",
    ]

    tp = sum(1 for item in positives if scan_detects(item))
    fn = len(positives) - tp
    fp = sum(1 for item in negatives if scan_detects(item))
    tn = len(negatives) - fp
    return tp, fp, fn, tn


def test_redaction_no_leaks() -> None:
    samples = [
        (f"value={CANARIES['openai']}\n", [CANARIES["openai"]]),
        (f"value={CANARIES['db']}\n", [CANARIES["db"]]),
        (f"value={CANARIES['url_query']}\n", [CANARIES["url_query"]]),
        (f"value={CANARIES['base64_openai']}\n", [CANARIES["base64_openai"]]),
        (f"value={CANARIES['base64_openai_double']}\n", [CANARIES["base64_openai_double"]]),
        (f"Authorization = \"Bearer {CANARIES['http_header']}\"\n", [CANARIES["http_header"]]),
        (f"AGENT_MAIL_TOKEN='{CANARIES['hex_token']}'\n", [CANARIES["hex_token"]]),
        (f"value=https://mcp.example.test/mcp?exaApiKey={CANARIES['uuid_token']}\n", [CANARIES["uuid_token"]]),
        (
            synthetic_token('val', 'ue=', '---', '--B', 'EGI', 'N P', 'RIV', 'ATE', ' KE', 'Y--', '---', '\nMI', 'IEv', 'QIB', 'ADA', 'NBg', 'kqh', 'kiG', '9w0', 'BAQ', 'EFA', 'ASC', '\n--', '---', 'END', ' PR', 'IVA', 'TE ', 'KEY', '---', '--\n'),
            [synthetic_token('---', '--B', 'EGI', 'N P', 'RIV', 'ATE', ' KE', 'Y--', '---'), synthetic_token('MII', 'EvQ', 'IBA', 'DAN', 'Bgk', 'qhk', 'iG9', 'w0B', 'AQE', 'FAA', 'SC')],
        ),
    ]
    for input_text, forbidden_values in samples:
        proc = run([str(BIN), "redact"], input_text=input_text)
        assert_true(proc.returncode == 0, f"redact failed: {proc.stderr}")
        for forbidden in forbidden_values:
            assert_true(forbidden not in proc.stdout, "redaction output leaked original canary")
        assert_true("[REDACTED:" in proc.stdout, "redaction marker missing")


def test_entropy_only_warns_not_blocks() -> None:
    sample = "bare token " + CANARIES["entropy"]
    proc = run([str(BIN), "scan"], input_text=sample)
    assert_true(proc.returncode == 0, "entropy scan failed")
    output = json.loads(proc.stdout)
    assert_true(output["count"] == 1, "entropy scan did not report warning-grade finding")
    assert_true(output["findings"][0]["kind"] == "HIGH_ENTROPY_TOKEN", "entropy scan reported wrong kind")

    proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=sample)
    assert_true(proc.returncode == 0, "entropy-only finding hard-blocked at default block threshold")

    proc = run([str(BIN), "redact"], input_text=sample)
    assert_true(proc.returncode == 0, "entropy redact failed")
    assert_true(CANARIES["entropy"] not in proc.stdout, "entropy redact leaked original token")
    assert_true("[REDACTED:HIGH_ENTROPY_TOKEN]" in proc.stdout, "entropy redact marker missing")


def test_vercel_deployment_metadata_not_redacted() -> None:
    deployment_id = "dpl_" + CANARIES["entropy"]
    inspector_id = CANARIES["entropy"]
    sample = json.dumps(
        {
            "id": deployment_id,
            "name": "harvest21",
            "url": "harvest21-fzenqfscx-harvest-21.vercel.app",
            "created": 1780433803117,
            "state": "READY",
            "target": None,
            "meta": {
                synthetic_token('git', 'hub', 'Com', 'mit', 'Sha'): synthetic_token('45b', '0b5', '745', 'a0e', '3f4', '8d3', 'a15', 'a50', '2c4', '595', '638', '530', '5d8', '8'),
                "githubCommitRef": "lane/gbrain-code-intel",
                "branchAlias": "harvest21-git-lane-gbrain-code-intel-harvest-21.vercel.app",
                "repoPushedAt": "1780433800000",
            },
            "inspectorUrl": "https://vercel.com/harvest-21/harvest21/" + inspector_id,
            "isRollbackCandidate": False,
        },
        indent=2,
    )
    proc = run([str(BIN), "redact", "--surface", "tool-output"], input_text=sample)
    assert_true(proc.returncode == 0, "vercel metadata redact failed")
    assert_true("[REDACTED:" not in proc.stdout, "vercel deployment metadata was falsely redacted")
    assert_true(deployment_id in proc.stdout and inspector_id in proc.stdout, "vercel deployment identifiers were not preserved")


def test_db_uri_boundary() -> None:
    text = f"{CANARIES['db']} trailing text"
    proc = run([str(BIN), "redact"], input_text=text)
    assert_true(proc.stdout == "[REDACTED:CREDENTIAL_URL] trailing text", "DB URI redaction boundary regressed")

    wrapped = f"({CANARIES['db']})."
    proc = run([str(BIN), "redact"], input_text=wrapped)
    assert_true(proc.stdout == "([REDACTED:CREDENTIAL_URL]).", "DB URI punctuation boundary regressed")


def test_claude_post_adapter() -> None:
    payload = {
        "tool_name": "Bash",
        "tool_input": {"command": "printf x"},
        "tool_response": {"stdout": f"token={CANARIES['openai']}\n", "stderr": ""},
    }
    proc = run([str(SECRET_SCAN)], input_text=json.dumps(payload))
    assert_true(proc.returncode == 0, f"secret-scan failed: {proc.stderr}")
    assert_true(CANARIES["openai"] not in proc.stdout, "secret-scan adapter leaked canary")
    output = json.loads(proc.stdout)
    assert_true(output.get("suppressOutput") is True, "PostToolUse adapter did not suppress original output")
    assert_true("updatedToolOutput" in output.get("hookSpecificOutput", {}), "PostToolUse adapter did not update output")


def test_pre_adapters() -> None:
    command_payload = {"tool_name": "Bash", "tool_input": {"command": f"echo {CANARIES['openai']}"}}
    for script in (SECRET_WRAP, CMD_GUARD):
        proc = run([str(script)], input_text=json.dumps(command_payload))
        assert_true(proc.returncode in (0, 2), f"{script.name} failed unexpectedly: {proc.stderr}")
        combined = proc.stdout + proc.stderr
        assert_true("deny" in combined or "BLOCKED" in combined, f"{script.name} did not deny secret command")
        assert_true(CANARIES["openai"] not in combined, f"{script.name} leaked command canary")

    outbound_payload = {"tool_name": "mcp__mcp-agent-mail__send", "tool_input": {"body": CANARIES["github"]}}
    proc = run([str(SECRET_MCP)], input_text=json.dumps(outbound_payload))
    assert_true("deny" in proc.stdout, "MCP adapter did not deny outbound secret")
    assert_true(CANARIES["github"] not in proc.stdout, "MCP adapter leaked canary")

    url_payload = {"tool_name": "WebFetch", "tool_input": {"url": CANARIES["url_query"]}}
    proc = run([str(SECRET_URL)], input_text=json.dumps(url_payload))
    assert_true("deny" in proc.stdout, "URL adapter did not deny secret URL")
    assert_true(CANARIES["url_query"] not in proc.stdout, "URL adapter leaked canary")

    encoded_payload = {"tool_name": "WebFetch", "tool_input": {"url": CANARIES["encoded_url"]}}
    proc = run([str(SECRET_URL)], input_text=json.dumps(encoded_payload))
    assert_true("deny" in proc.stdout, "URL adapter did not deny encoded secret URL")
    assert_true(CANARIES["encoded_url"] not in proc.stdout, "URL adapter leaked encoded canary")


def test_filter_adapter() -> None:
    proc = run([str(SECRET_FILTER)], input_text=f"token={CANARIES['anthropic']}\n")
    assert_true(proc.returncode == 0, f"secret-filter failed: {proc.stderr}")
    assert_true(CANARIES["anthropic"] not in proc.stdout, "secret-filter leaked canary")


def test_redaction_output_is_idempotently_safe_to_rescan() -> None:
    sample = "/tmp/secret-scanning-system.md:316:api_key=" + CANARIES["github"] + "\n"
    redacted = run([str(BIN), "redact", "--surface", "tool-output"], input_text=sample)
    assert_true(redacted.returncode == 0, f"redaction failed: {redacted.stderr}")
    assert_true(CANARIES["github"] not in redacted.stdout, "redaction leaked canary")
    assert_true("[REDACTED:" in redacted.stdout, "redaction marker missing")

    rescanned = run(
        [str(BIN), "scan", "--surface", "tool-output", "--quiet", "--fail-on-detect"],
        input_text=redacted.stdout,
    )
    assert_true(rescanned.returncode == 0, "redacted output was still detected as secret material")

    marker_line = "/tmp/secret-scanning-system.md:[REDACTED:SENSITIVE_ASSIGNMENT]\n"
    marker_scan = run(
        [str(BIN), "scan", "--surface", "tool-output", "--quiet", "--fail-on-detect"],
        input_text=marker_line,
    )
    assert_true(marker_scan.returncode == 0, "ASG redaction marker was detected as secret material")


def test_path_listing_no_false_redaction() -> None:
    proc = run([str(BIN), "redact", "--surface", "tool-output"], input_text=PATH_LISTING_SAMPLE)
    assert_true(proc.returncode == 0, f"path listing redact failed: {proc.stderr}")
    assert_true("[REDACTED:" not in proc.stdout, "path listing was falsely redacted")
    assert_true(proc.stdout == PATH_LISTING_SAMPLE, "path listing output changed")

    proc = run([str(BIN), "scan", "--surface", "tool-output", "--quiet", "--fail-on-detect"], input_text=PATH_LISTING_SAMPLE)
    assert_true(proc.returncode == 0, "path listing was falsely detected as secret material")

    proc = run([str(BIN), "scan", "--surface", "tool-output", "--quiet", "--fail-on-detect"], input_text=SOURCE_LISTING_SOFTWRAP_FP_SAMPLE)
    assert_true(proc.returncode == 0, "aggregated source-listing output was falsely soft-wrap detected")

    extensionless_script_listing = (
        '{{ASG_HOME}}/.local/bin/agent-secret-guard-tests:131:'
        'SOURCE_LISTING_SOFTWRAP_FP_SAMPLE = """{{ASG_HOME}}/.local/share/agent-secret-guard/README.md:32:`~/.local/run/agent-secret-guard/asg.sock`; the directory is `0700` and the\n'
    )
    proc = run([str(BIN), "scan", "--surface", "tool-output", "--quiet", "--fail-on-detect"], input_text=extensionless_script_listing)
    assert_true(proc.returncode == 0, "extensionless source-listing prefix was falsely detected as an assignment")


