def synthetic_token(*parts: str) -> str:
    return "".join(parts)


def escaped_hex(value: str) -> str:
    return "".join(f"\\x{ord(char):02x}" for char in value)


def escaped_unicode(value: str) -> str:
    return "".join(f"\\u{ord(char):04x}" for char in value)


def percent_encoded(value: str) -> str:
    return "".join(f"%{byte:02X}" for byte in value.encode())


def base64_utf16le(value: str) -> str:
    return base64.b64encode(value.encode("utf-16le")).decode("ascii")


def base64url_json(value: dict[str, str]) -> str:
    raw = json.dumps(value, separators=(",", ":")).encode("utf-8")
    return base64.urlsafe_b64encode(raw).decode("ascii").rstrip("=")


def ascii_text(values: list[int]) -> str:
    return "".join(chr(value) for value in values)


def github_app_installation_token() -> str:
    jwt = ".".join(
        (
            base64url_json({"alg": "RS256", "typ": "JWT"}),
            base64url_json({"iss": "github", "sub": "installation"}),
            "abcdefghijklmnop",
        )
    )
    return synthetic_token("ghs_", "123456_", jwt)


