        "cat ~/.vault-token",
    ]
    for command in blocked_commands:
        proc = run([str(ASG_BASH_BLOCK)], input_text=command)
        assert_true(proc.returncode == 2, f"asg-bash-command-block missed leaky command: {command.split()[0]}")
        assert_true(command not in proc.stdout + proc.stderr, "bash command policy leaked blocked command")

        payload = {"tool_input": {"command": command}}
        proc = run([str(CMD_GUARD)], input_text=json.dumps(payload))
        assert_true(proc.returncode == 2, f"cmd-leak-guard missed leaky command: {command.split()[0]}")
        assert_true(command not in proc.stdout + proc.stderr, "cmd-leak-guard leaked blocked command")

    safe_commands = [
