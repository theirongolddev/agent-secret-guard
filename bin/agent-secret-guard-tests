def test_vcs_diff_false_positive_regressions() -> None:
    proc = run([str(BIN), "scan", "--surface", "vcs-diff", "--quiet", "--fail-on-detect"], input_text=VCS_FALSE_POSITIVE_SAMPLE)
    assert_true(proc.returncode == 0, "vcs-diff prose/identifier sample was falsely detected")

    result = json_scan("aws_secret_access_key=" + CANARIES["aws_secret"])
    assert_true(result["count"] == 1, "AWS secret access key was missed")
    assert_true(result["findings"][0]["kind"] == "AWS_SECRET_ACCESS_KEY", "AWS secret access key has wrong kind")

    proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text="aws_access_key_id=" + CANARIES["aws"])
    assert_true(proc.returncode == 0, "standalone AWS access key identifier was treated as a blocking secret")

    result = json_scan(f"aws_access_key_id={CANARIES['aws']}\naws_secret_access_key={CANARIES['aws_secret']}")
    kinds = {finding["kind"] for finding in result["findings"]}
    assert_true("AWS_ACCESS_KEY_ID" in kinds, "AWS access key identifier was not promoted when paired")
    assert_true("AWS_SECRET_ACCESS_KEY" in kinds, "AWS secret access key was missed in pair")


def test_ref_and_path_slug_redaction_regressions() -> None:
    for sample in REF_PATH_SLUG_FP_SAMPLES:
        proc = run([str(BIN), "redact", "--surface", "tool-output"], input_text=sample)
        assert_true(proc.returncode == 0, f"ref/path slug redact failed: {proc.stderr}")
        assert_true("[REDACTED:" not in proc.stdout, "VCS ref or doc path was falsely redacted as a high-entropy secret")
        proc = run([str(BIN), "scan", "--surface", "tool-output", "--quiet", "--fail-on-detect"], input_text=sample)
        assert_true(proc.returncode == 0, "VCS ref or doc path was treated as a blocking secret")

    # Adjacent positives: a real high-entropy secret must still redact even when
    # it sits next to a slash or hyphen, or behind a slug-shaped prefix. The
    # "deploy/key-" carrier matches the slug allowlist's character preconditions
    # (slash + hyphen) and is rescued only by the long-opaque-run guard.
    secret = CANARIES["aws_secret"]
    for carrier in (secret, "deploy/key-" + secret, "release-" + secret, "slug=deploy/key-" + secret):
        proc = run([str(BIN), "redact", "--surface", "tool-output"], input_text=carrier)
        assert_true(proc.returncode == 0, f"secret carrier redact failed: {proc.stderr}")
        assert_true("[REDACTED:" in proc.stdout, "adjacent high-entropy secret was suppressed by the ref/path slug allowlist")
        assert_true(secret not in proc.stdout, "secret value leaked through redaction")


