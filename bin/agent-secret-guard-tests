        "kubectl get pods -o wide",
        "kubectl get secrets",
        "vercel env ls",
        "docker login --username user --password-stdin",
        "git remote -v",
        "jj git remote list",
        "git config --get-all credential.helper",
        "cat .infisical.json",
        "cat /tmp/project/.infisical.json",
        "infisical run --env=dev -- npm test",
        "infisical secrets --env=dev -o json | jq -r '.[].secretKey'",
        'curl -H "Authorization: Bearer $TOKEN" https://example.test',
        'curl -H "Authorization: Bearer ${TOKEN}" https://example.test',
        "TOKEN=$(infisical secrets get CIRCLECI_API_TOKEN --env=dev --plain 2>/dev/null)\ncurl -s -H \"Circle-Token: $TOKEN\" https://circleci.com/api/v2/workflow/example/job\necho \"job lookup complete\"",
    ]
    for command in safe_commands:
        proc = run([str(ASG_BASH_BLOCK)], input_text=command)
        assert_true(proc.returncode == 0, f"asg-bash-command-block false-positive on safe command: {command}")

        payload = {"tool_input": {"command": command}}
        proc = run([str(CMD_GUARD)], input_text=json.dumps(payload))
        assert_true(proc.returncode == 0, f"cmd-leak-guard false-positive on safe command: {command}")

    still_blocked_commands = [
        "echo \"$CIRCLECI_API_TOKEN\"",
        "TOKEN=$(infisical secrets get CIRCLECI_API_TOKEN --env=dev --plain); echo \"$TOKEN\"",
    ]
    for command in still_blocked_commands:
        proc = run([str(ASG_BASH_BLOCK)], input_text=command)
        assert_true(proc.returncode == 2, "asg-bash-command-block allowed printed secret reference")


def test_secret_push_guard_jj_bookmark_scope() -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        root = Path(temp_dir) / "repo"
        fake_bin = Path(temp_dir) / "bin"
        log_path = Path(temp_dir) / "jj.log"
        root.mkdir()
        fake_bin.mkdir()
        (root / ".jj").mkdir()
        fake_jj = fake_bin / "jj"
        fake_jj.write_text(
            "\n".join(
                [
                    "#!/bin/sh",
                    "printf '%s\\n' \"$*\" >> \"$JJ_FAKE_LOG\"",
                    "case \"$1\" in",
                    "  log) printf '%s\\n' \"${JJ_FAKE_LOG_CONTENT:-}\" ;;",
                    "  diff) printf '%s\\n' \"${JJ_FAKE_DIFF_CONTENT:-}\" ;;",
                    "esac",
                    "",
                ]
            ),
            encoding="utf-8",
        )
        fake_jj.chmod(0o755)

        def invoke_push(log_content: str, diff_content: str = "") -> subprocess.CompletedProcess[str]:
            env = os.environ.copy()
            env["PATH"] = f"{fake_bin}{os.pathsep}{env.get('PATH', '')}"
            env["JJ_FAKE_LOG"] = str(log_path)
            env["JJ_FAKE_LOG_CONTENT"] = log_content
            env["JJ_FAKE_DIFF_CONTENT"] = diff_content
            env["ASG_DAEMON_SOCKET"] = str(Path(temp_dir) / "missing-asg.sock")
            env["ASG_DAEMON_PID"] = str(Path(temp_dir) / "missing-asg.pid")
            payload = {"tool_input": {"command": "jj git push -b master"}}
            return subprocess.run(
                [str(SECRET_PUSH)],
                input=json.dumps(payload),
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                cwd=root,
                env=env,
                check=False,
            )

        proc = invoke_push(VCS_FALSE_POSITIVE_SAMPLE)
        assert_true(proc.returncode == 0, f"secret-push-guard failed: {proc.stderr}")
        assert_true(json.loads(proc.stdout).get("continue") is True, "secret-push-guard rejected benign vcs-diff prose")
        rendered = log_path.read_text(encoding="utf-8")
        assert_true("remote_bookmarks()..master" in rendered, "secret-push-guard did not scope jj push to pushed bookmark")
        assert_true("remote_bookmarks()..@" not in rendered, "secret-push-guard scanned @ for bookmark push")

        weak_entropy = "bare token " + CANARIES["entropy"]
        proc = invoke_push(weak_entropy)
        assert_true(proc.returncode == 0, "secret-push-guard failed on weak entropy sample")
        assert_true(json.loads(proc.stdout).get("continue") is True, "secret-push-guard hard-blocked entropy-only finding")

        proc = invoke_push("OPENAI_API_KEY=" + CANARIES["openai"])
        combined = proc.stdout + proc.stderr
        assert_true(proc.returncode == 0, "secret-push-guard deny path should use hook JSON")
        assert_true(CANARIES["openai"] not in combined, "secret-push-guard leaked blocked push canary")
        output = json.loads(proc.stdout)
        assert_true(output["hookSpecificOutput"]["permissionDecision"] == "deny", "secret-push-guard missed provider secret")


def test_harness_neutral_wrappers() -> None:
    payload = {"tool": {"input": {"apiKey": CANARIES["openai"]}}}
    proc = run([str(ASG_JSON_BLOCK)], input_text=json.dumps(payload))
    assert_true(proc.returncode == 2, "asg-json-block did not block secret JSON")
    assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "asg-json-block leaked canary")

    proc = run([str(ASG_JSON_REDACT)], input_text=json.dumps(payload))
    assert_true(proc.returncode == 0, "asg-json-redact failed")
    assert_true(CANARIES["openai"] not in proc.stdout, "asg-json-redact leaked canary")

    proc = run([str(ASG_STREAM_REDACT)], input_text=f"token={CANARIES['github']}")
    assert_true(CANARIES["github"] not in proc.stdout, "asg-stream-redact leaked canary")

    proc = run([str(ASG_BASH_BLOCK)], input_text=f"echo {CANARIES['openai']}")
    assert_true(proc.returncode == 2, "asg-bash-command-block did not block secret command")
    assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "asg-bash-command-block leaked canary")

    proc = run([str(ASG_VCS_BLOCK)], input_text=f"+ API_KEY={CANARIES['openai']}")
    assert_true(proc.returncode == 2, "asg-vcs-diff-block did not block secret diff")
    assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "asg-vcs-diff-block leaked canary")

    proc = run([str(ASG_RUN), "python3", "-c", 'print("sk-"+"proj-"+"abcdefghijklmnopqrstuvwxyz"+"123456")'])
    assert_true(proc.returncode == 0, f"asg-run wrapped command failed: {proc.stderr}")
    assert_true(CANARIES["openai"] not in proc.stdout, "asg-run leaked generated output canary")
    assert_true("[REDACTED:" in proc.stdout, "asg-run did not redact generated output")

    proc = run([str(ASG_RUN), "echo", CANARIES["openai"]])
    assert_true(proc.returncode == 2, "asg-run did not block secret argv")
    assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "asg-run leaked blocked argv canary")


def test_codex_adapter() -> None:
    pre = {"hook_event_name": "PreToolUse", "tool_name": "Bash", "tool_input": {"command": f"echo {CANARIES['openai']}"}}
    proc = run([str(ASG_CODEX_HOOK)], input_text=json.dumps(pre))
    assert_true(proc.returncode == 0, f"codex pre hook failed: {proc.stderr}")
    assert_true(CANARIES["openai"] not in proc.stdout, "codex pre hook leaked canary")
    output = json.loads(proc.stdout)
    assert_true(output["hookSpecificOutput"]["permissionDecision"] == "deny", "codex pre hook did not deny")

    post = {"hook_event_name": "PostToolUse", "tool_name": "Bash", "tool_response": {"stdout": CANARIES["github"]}}
    proc = run([str(ASG_CODEX_HOOK)], input_text=json.dumps(post))
    assert_true(CANARIES["github"] not in proc.stdout, "codex post hook leaked canary")
    output = json.loads(proc.stdout)
    assert_true(output["decision"] == "block", "codex post hook did not block")

    post_key = {"hook_event_name": "PostToolUse", "tool_name": "Bash", "tool_response": {CANARIES["github"]: "value"}}
    proc = run([str(ASG_CODEX_HOOK)], input_text=json.dumps(post_key))
    assert_true(CANARIES["github"] not in proc.stdout, "codex post key hook leaked canary")
    output = json.loads(proc.stdout)
    assert_true(output["decision"] == "block", "codex post hook did not block secret-bearing key")

    prompt = {"hook_event_name": "UserPromptSubmit", "prompt": CANARIES["anthropic"]}
    proc = run([str(ASG_CODEX_HOOK)], input_text=json.dumps(prompt))
    assert_true(CANARIES["anthropic"] not in proc.stdout, "codex prompt hook leaked canary")
    output = json.loads(proc.stdout)
    assert_true(output == {}, "codex prompt hook should allow prompt content for false-positive reports")


def test_hook_observation_telemetry_no_payload() -> None:
    with tempfile.TemporaryDirectory() as tmp:
        telemetry_path = Path(tmp) / "hook-events.jsonl"
        env = os.environ.copy()
        env["ASG_HOOK_TELEMETRY_PATH"] = str(telemetry_path)
        env["ASG_DISABLE_HOOK_TELEMETRY"] = "0"
        payload = {"hook_event_name": "UserPromptSubmit", "prompt": "api_key=" + CANARIES["openai"]}

        proc = run([str(ASG_CODEX_HOOK)], input_text=json.dumps(payload), env=env)
        assert_true(proc.returncode == 0, f"codex telemetry hook failed: {proc.stderr}")
        assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "codex hook leaked telemetry canary")
        assert_true(telemetry_path.exists(), "hook telemetry file was not created")

        telemetry_text = telemetry_path.read_text(encoding="utf-8")
        assert_true(CANARIES["openai"] not in telemetry_text, "hook telemetry leaked canary")
        assert_true("api_key" not in telemetry_text and "prompt" not in telemetry_text, "hook telemetry logged payload data")

        rows = [json.loads(line) for line in telemetry_text.splitlines()]
        assert_true(len(rows) == 1, "hook telemetry wrote unexpected row count")
        assert_true(set(rows[0]) == {"event", "harness", "ts"}, "hook telemetry contains unexpected keys")
        assert_true(rows[0]["harness"] == "codex", "hook telemetry harness mismatch")
        assert_true(rows[0]["event"] == "UserPromptSubmit", "hook telemetry event mismatch")

        summary = asg.hook_observation_summary(telemetry_path)
        item = summary["events"].get("codex:UserPromptSubmit")
        assert_true(item and item["count"] == 1, "hook telemetry summary missing codex prompt event")

        disabled_path = Path(tmp) / "disabled.jsonl"
        env["ASG_HOOK_TELEMETRY_PATH"] = str(disabled_path)
        env["ASG_DISABLE_HOOK_TELEMETRY"] = "1"
        proc = run([str(ASG_CODEX_HOOK)], input_text=json.dumps({"hook_event_name": "UserPromptSubmit", "prompt": "hello"}), env=env)
        assert_true(proc.returncode == 0, "disabled telemetry hook failed")
        assert_true(not disabled_path.exists(), "disabled hook telemetry still wrote a file")


def test_installer_manifest() -> None:
    proc = run([str(ASG_INSTALL)])
    assert_true(proc.returncode == 0, f"installer failed: {proc.stderr}")
    manifest = json.loads(proc.stdout)
    assert_true(manifest["commands"]["agent-secret-guard"]["present"] is True, "manifest missing core CLI")
    assert_true(manifest["adapter_contract"]["json_block"].endswith("asg-json-block"), "manifest missing generic adapter")
    assert_true(manifest["adapter_contract"]["codex_hook"].endswith("asg-codex-hook"), "manifest missing codex adapter")
    assert_true("cursor_hooks" in manifest["adapter_contract"], "manifest missing cursor adapter")
    assert_true(manifest["adapter_contract"]["cursor_hooks"]["beforeSubmitPrompt"].endswith("asg-cursor-before-prompt"), "manifest missing cursor prompt wrapper")
    assert_true(manifest["adapter_contract"]["cursor_hooks"]["preToolUse"].endswith("asg-cursor-pretooluse"), "manifest missing cursor wrapper")
    assert_true(manifest["adapter_contract"]["cursor_hooks"]["beforeMCPExecution"].endswith("asg-cursor-before-mcp"), "manifest missing cursor mcp wrapper")
    assert_true(manifest["adapter_contract"]["cursor_hooks"]["afterAgentResponse"].endswith("asg-cursor-after-agent-response"), "manifest missing cursor agent response wrapper")
    assert_true(manifest["eval_corpus"]["present"] is True, "manifest missing eval corpus")
    assert_true("gitleaks" in manifest["external_scanners"], "manifest missing external scanner inventory")
    assert_true("active_harness_coverage" in manifest, "manifest missing active harness coverage")
    assert_true("generated_harness_coverage" in manifest, "manifest missing generated harness coverage")
    assert_true(manifest["generated_harness_coverage"]["codex"]["coverage"] == "covered", "generated codex hooks not covered")
    assert_true(manifest["generated_harness_coverage"]["codex"]["command_health"]["static_failures"] == 0, "generated codex hooks have brittle commands")
    assert_true(manifest["generated_harness_coverage"]["cursor"]["coverage"] == "covered", "generated cursor hooks not covered")
    assert_true(manifest["generated_harness_coverage"]["cursor"]["command_health"]["static_failures"] == 0, "generated cursor hooks have brittle commands")
    assert_true("runtime_probe" in manifest, "manifest missing runtime probe")
    assert_true(manifest["runtime_probe"]["generated_codex"]["failures"] == [], "generated codex runtime probe failed")
    assert_true(manifest["runtime_probe"]["generated_cursor"]["failures"] == [], "generated cursor runtime probe failed")
    for snippet_path in manifest["snippets"].values():
        assert_true(Path(snippet_path).exists(), f"missing snippet {snippet_path}")


def test_adapter_proof() -> None:
    proc = run([str(BIN), "prove"])
    assert_true(proc.returncode == 0, f"adapter proof failed: {proc.stderr}")
    combined = proc.stdout + proc.stderr
    for canary in CANARIES.values():
        assert_true(canary not in combined, "adapter proof leaked canary")
    output = json.loads(proc.stdout)
    assert_true(output["ok"] is True, "adapter proof reported failure")
    assert_true(output["failed"] == 0, "adapter proof has failed cases")
    assert_true(output["case_count"] >= 20, "adapter proof coverage is too thin")
    for harness in ("generic", "claude", "codex", "cursor"):
        assert_true(harness in output["harnesses"], f"adapter proof missing harness {harness}")


def test_active_harness_coverage() -> None:
    with tempfile.TemporaryDirectory() as tmp:
        base = Path(tmp)
        claude_path = base / "claude-settings.json"
        codex_path = base / "codex-hooks.json"
        cursor_path = base / "cursor-hooks.json"

        fake_secret = CANARIES["openai"]
        claude_path.write_text(
            json.dumps(
                {
                    "hooks": {
                        "PreToolUse": [
                            {
                                "hooks": [
                                    {"type": "command", "command": f"/bin/{marker} --opaque {fake_secret}"}
                                    for marker in asg.CLAUDE_HOOK_MARKERS["PreToolUse"]
                                ]
                            }
                        ],
                        "PostToolUse": [
                            {
                                "hooks": [
                                    {"type": "command", "command": f"/bin/secret-scan --opaque {fake_secret}"}
                                ]
                            }
                        ],
                    }
                }
            )
        )
        codex_path.write_text(
            json.dumps(
                {
                    "hooks": {
                        event: [
                            {
                                "hooks": [
                                    {"type": "command", "command": str(ASG_CODEX_HOOK)}
                                ]
                            }
                        ]
                        for event in asg.CODEX_HOOK_EVENTS
                    }
                }
            )
        )
        cursor_wrappers = {
            "beforeSubmitPrompt": "asg-cursor-before-prompt",
            "preToolUse": "asg-cursor-pretooluse",
            "beforeShellExecution": "asg-cursor-before-shell",
            "beforeMCPExecution": "asg-cursor-before-mcp",
            "beforeReadFile": "asg-cursor-before-read",
            "postToolUse": "asg-cursor-posttooluse",
            "afterShellExecution": "asg-cursor-after-shell",
            "afterMCPExecution": "asg-cursor-after-mcp",
            "afterFileEdit": "asg-cursor-after-file-edit",
            "afterAgentResponse": "asg-cursor-after-agent-response",
            "afterAgentThought": "asg-cursor-after-agent-thought",
        }
        cursor_path.write_text(
            json.dumps(
                {
                    "version": 1,
                    "hooks": {
                        event: [
                            {"command": str(Path.home() / f".local/bin/{cursor_wrappers[event]}")}
                        ]
                        for event in asg.CURSOR_HOOK_EVENTS
                    },
                }
            )
        )
        coverage = asg.active_harness_coverage(
            {"claude": claude_path, "codex": codex_path, "cursor": cursor_path}
        )
        assert_true(coverage["claude"]["coverage"] == "covered", "claude active coverage not detected")
        assert_true(coverage["codex"]["coverage"] == "covered", "codex active coverage not detected")
        assert_true(coverage["cursor"]["coverage"] == "covered", "cursor active coverage not detected")
        assert_true(coverage["codex"]["command_health"]["static_failures"] == 0, "codex command health flagged valid wrapper")
        assert_true(coverage["cursor"]["command_health"]["static_failures"] == 0, "cursor command health flagged valid wrappers")
        assert_true(fake_secret not in json.dumps(coverage), "coverage output leaked hook command value")

        codex_path.write_text(
            json.dumps(
                {
                    "hooks": {
                        event: [
                            {
                                "hooks": [
                                    {"type": "command", "command": "/bin/asg-fast codex-hook"}
                                ]
                            }
                        ]
                        for event in asg.CODEX_HOOK_EVENTS
                    }
                }
            )
        )
        coverage = asg.active_harness_coverage(
            {"claude": claude_path, "codex": codex_path, "cursor": cursor_path}
        )
        assert_true(coverage["codex"]["coverage"] == "missing", "codex direct command with args was treated as covered")

        codex_path.write_text(
            json.dumps(
                {
                    "hooks": {
                        event: [
                            {
                                "hooks": [
                                    {"type": "command", "command": "bash /tmp/asg-codex-hook"}
                                ]
                            }
                        ]
                        for event in asg.CODEX_HOOK_EVENTS
                    }
                }
            )
        )
        coverage = asg.active_harness_coverage(
            {"claude": claude_path, "codex": codex_path, "cursor": cursor_path}
        )
        assert_true(coverage["codex"]["coverage"] == "covered", "codex marker coverage regressed")
        assert_true(coverage["codex"]["command_health"]["static_failures"] == len(asg.CODEX_HOOK_EVENTS), "codex command health missed bare bash")

        cursor_path.write_text(
            json.dumps(
                {
                    "version": 1,
                    "hooks": {
                        event: [
                            {"command": f"/bin/asg-fast {'cursor-hook'} --event {event}"}
                        ]
                        for event in asg.CURSOR_HOOK_EVENTS
                    },
                }
            )
        )
        coverage = asg.active_harness_coverage(
            {"claude": claude_path, "codex": codex_path, "cursor": cursor_path}
        )
        assert_true(coverage["cursor"]["coverage"] == "missing", "cursor direct command with args was treated as covered")
        assert_true(coverage["cursor"]["command_health"]["static_failures"] == len(asg.CURSOR_HOOK_EVENTS), "cursor command health missed direct asg-fast hooks")

        cursor_path.write_text(json.dumps({"version": 1, "hooks": {"preToolUse": []}}))
        coverage = asg.active_harness_coverage(
            {"claude": claude_path, "codex": codex_path, "cursor": cursor_path}
        )
        assert_true(coverage["cursor"]["coverage"] == "missing", "cursor missing coverage not reported")
        assert_true("postToolUse" in coverage["cursor"]["missing_events"], "cursor missing event not reported")


def test_installer_active_config_apply() -> None:
    with tempfile.TemporaryDirectory() as tmp:
        base = Path(tmp)
        claude_path = base / "claude-settings.json"
        codex_path = base / "codex-hooks.json"
        cursor_path = base / "cursor-hooks.json"
        fake_secret = CANARIES["openai"]

        claude_path.write_text(
            json.dumps(
                {
                    "hooks": {
                        "PreToolUse": [
                            {
                                "matcher": "Bash",
                                "hooks": [{"type": "command", "command": f"/tmp/existing-guard --opaque {fake_secret}"}],
                            }
                        ]
                    }
                }
            )
        )
        codex_path.write_text(
            json.dumps(
                {
                    "hooks": {
                        "UserPromptSubmit": [
                            {"hooks": [{"type": "command", "command": f"/tmp/existing-guard --opaque {fake_secret}"}]}
                        ]
                    }
                }
            )
        )
        cursor_path.write_text(
            json.dumps(
                {
                    "version": 1,
                    "hooks": {
                        "preToolUse": [
                            {"command": f"/tmp/existing-guard --opaque {fake_secret}"}
                        ]
                    },
                }
            )
        )
        args = [
            "--claude-config",
            str(claude_path),
            "--codex-config",
            str(codex_path),
            "--cursor-config",
            str(cursor_path),
        ]
        dry_run = run([str(ASG_INSTALL), "--dry-run", *args])
        assert_true(dry_run.returncode == 0, f"installer dry-run failed: {dry_run.stderr}")
        assert_true(fake_secret not in dry_run.stdout, "installer dry-run leaked config command value")
        dry_manifest = json.loads(dry_run.stdout)
        assert_true(dry_manifest["active_config_install"]["mode"] == "dry-run", "installer dry-run mode missing")
        assert_true(dry_manifest["active_config_install"]["codex"]["changed"] is True, "dry-run did not report codex change")
        assert_true(dry_manifest["runtime_probe"]["generated_claude"]["failures"] == [], "dry-run generated claude probe failed")
        assert_true(dry_manifest["runtime_probe"]["generated_codex"]["failures"] == [], "dry-run generated codex probe failed")

        first_apply = run([str(ASG_INSTALL), "--apply", *args])
        assert_true(first_apply.returncode == 0, f"installer apply failed: {first_apply.stderr}")
        assert_true(fake_secret not in first_apply.stdout, "installer apply leaked config command value")
        manifest = json.loads(first_apply.stdout)
        assert_true(manifest["active_config_install"]["mode"] == "apply", "installer apply mode missing")
        assert_true(manifest["runtime_probe"]["active_claude"]["failures"] == [], "installer active claude probe failed")
        assert_true(manifest["runtime_probe"]["active_codex"]["failures"] == [], "installer active codex probe failed")
        assert_true(manifest["runtime_probe"]["active_cursor"]["failures"] == [], "installer active cursor probe failed")
        assert_true(manifest["generated_harness_coverage"]["codex"]["command_health"]["static_failures"] == 0, "installer generated codex command health failed")
        assert_true(manifest["generated_harness_coverage"]["cursor"]["command_health"]["static_failures"] == 0, "installer generated cursor command health failed")
        assert_true(manifest["active_harness_coverage"]["codex"]["command_health"]["static_failures"] >= 1, "installer did not report preserved brittle non-ASG hook")
        for harness in ("claude", "codex", "cursor"):
            result = manifest["active_config_install"][harness]
            assert_true(result["runtime_probe"]["failures"] == [], f"{harness} pre-write runtime probe failed")
            assert_true(result["runtime_probe"]["checked"] >= 1, f"{harness} pre-write runtime probe did not run")
            assert_true(result["applied"] is True, f"{harness} config was not applied")
            assert_true(result["backup_path"], f"{harness} config backup path missing")
            assert_true(Path(result["backup_path"]).exists(), f"{harness} backup file missing")
            assert_true((Path(result["backup_path"]).stat().st_mode & 0o777) == 0o600, f"{harness} backup mode not 0600")
            assert_true((Path(result["path"]).stat().st_mode & 0o777) == 0o600, f"{harness} config mode not 0600")

        coverage = asg.active_harness_coverage({"claude": claude_path, "codex": codex_path, "cursor": cursor_path})
        assert_true(coverage["claude"]["coverage"] == "covered", "applied claude coverage missing")
        assert_true(coverage["codex"]["coverage"] == "covered", "applied codex coverage missing")
        assert_true(coverage["cursor"]["coverage"] == "covered", "applied cursor coverage missing")

        second_apply = run([str(ASG_INSTALL), "--apply", *args])
        assert_true(second_apply.returncode == 0, f"installer second apply failed: {second_apply.stderr}")
        assert_true(fake_secret not in second_apply.stdout, "installer second apply leaked config command value")
        second_manifest = json.loads(second_apply.stdout)
        for harness in ("claude", "codex", "cursor"):
            assert_true(second_manifest["active_config_install"][harness]["changed"] is False, f"{harness} apply not idempotent")


def test_eval_corpus() -> None:
    proc = run([str(BIN), "eval", "--corpus", str(ASG_CORPUS)])
    assert_true(proc.returncode == 0, f"eval corpus failed: {proc.stderr}")
    for canary in CANARIES.values():
        assert_true(canary not in proc.stdout, "eval output leaked canary")
    output = json.loads(proc.stdout)
    assert_true(output["ok"] is True, "eval corpus reported failures")
    assert_true(output["metrics"]["fp"] == 0, "eval corpus has false positives")
    assert_true(output["metrics"]["fn"] == 0, "eval corpus has false negatives")
    assert_true(output["metrics"]["wrong_kind"] == 0, "eval corpus has wrong-kind detections")
    coverage = output.get("coverage", {})
    summary = coverage.get("summary", {})
    quality = coverage.get("quality", {})
    requirements = coverage.get("requirements", {})
    assert_true(summary.get("failed") == 0, "eval corpus has failing requirement coverage")
    assert_true(summary.get("requirements", 0) >= 20, "eval corpus requirement coverage is too thin")
    assert_true(quality.get("status") == "pass", "eval corpus quality checks failed")
    assert_true(quality.get("catalog_requirements") == quality.get("covered_requirements"), "eval catalog/coverage mismatch")
    assert_true(not quality.get("missing_catalog_entries"), "eval corpus has requirements missing from catalog")
    assert_true(not quality.get("unused_catalog_entries"), "eval corpus catalog has unused requirements")
    assert_true(not quality.get("blank_descriptions"), "eval corpus catalog has blank descriptions")
    assert_true(not quality.get("thin_requirements"), "eval corpus has thin requirement coverage")
    assert_true(not quality.get("positive_without_negative"), "eval corpus has positive requirements without negatives")
    assert_true(not quality.get("missing_positive_kinds"), "eval corpus has detectors without positive cases")
    assert_true(not quality.get("missing_detector_hints"), "eval corpus has detectors without hints")
    assert_true(not quality.get("short_detector_hints"), "eval corpus has overly broad detector literal hints")
    assert_true(not quality.get("positive_without_detector_hint"), "eval corpus has detector positives that bypass hints")
    assert_true(quality.get("min_cases_per_requirement", 0) >= 2, "eval corpus quality minimum is too low")
    for requirement in (
        "provider:anthropic",
        "provider:huggingface",
        "provider:vercel",
        "provider:cloudflare",
        "provider:linear",
        "provider:notion",
        "provider:sentry",
        "provider:supabase",
        "provider:source-control",
        "provider:observability",
        "provider:secrets-management",
        "provider:doppler",
        "provider:frameio",
        "provider:lob",
        "provider:mapbox",
        "provider:dropbox",
        "provider:launchdarkly",
        "provider:clojars",
        "provider:cratesio",
        "provider:xai",
        "provider:databento",
        "provider:azure-openai",
        "provider:bitrise",
        "provider:inngest",
        "provider:unkey",
        "provider:groq",
        "provider:tavily",
        "provider:nvidia",
        "provider:langsmith",
        "provider:jina",
        "provider:langfuse",
        "provider:pinecone",
        "provider:ssemble",
        "provider:firecrawl",
        "provider:cursor",
        "provider:openvsx",
        "provider:pagarme",
        "provider:terraform",
        "provider:qdrant",
        "provider:api-platform",
        "provider:communications",
        "encoded:escapes",
        "encoded:html-entity",
        "encoded:percent",
        "encoded:hex",
        "encoded:utf16-base64",
        "structured:json-object-key",
        "obfuscation:display-normalization",
        "obfuscation:soft-wrap",
        "obfuscation:chunked-token",
        "command:shell-leak-policy",
        "negative:active-fp-recommendations",
    ):
        assert_true(requirement in requirements, f"eval corpus missing requirement {requirement}")
        assert_true(requirements[requirement]["status"] == "pass", f"eval corpus requirement failed: {requirement}")
    assert_true(all(case.get("requirements") for case in output["cases"]), "eval cases missing requirement labels")


def test_eval_corpus_quality_enforced() -> None:
    with tempfile.TemporaryDirectory(prefix="asg-test-") as temp_dir:
        corpus_path = Path(temp_dir) / "corpus.json"
        corpus = json.loads(ASG_CORPUS.read_text())
        corpus["requirements"].pop("provider:openai", None)
        corpus_path.write_text(json.dumps(corpus))
        proc = run([str(BIN), "eval", "--quiet", "--corpus", str(corpus_path)])
        assert_true(proc.returncode == 1, "eval did not fail on missing requirement catalog entry")

        corpus = json.loads(ASG_CORPUS.read_text())
        corpus["requirements"]["unused:test-only"] = {"description": "Unused test-only requirement."}
        corpus_path.write_text(json.dumps(corpus))
        proc = run([str(BIN), "eval", "--quiet", "--corpus", str(corpus_path)])
        assert_true(proc.returncode == 1, "eval did not fail on unused requirement catalog entry")

        corpus = json.loads(ASG_CORPUS.read_text())
        corpus["cases"] = [
            case
            for case in corpus["cases"]
            if not (case.get("label") == "negative" and "provider:openai" in case.get("requirements", []))
        ]
        corpus_path.write_text(json.dumps(corpus))
        proc = run([str(BIN), "eval", "--quiet", "--corpus", str(corpus_path)])
        assert_true(proc.returncode == 1, "eval did not fail on positive-only requirement coverage")

        corpus = json.loads(ASG_CORPUS.read_text())
        corpus["cases"] = [
            case
            for case in corpus["cases"]
            if "GITHUB_FINE_GRAINED_PAT" not in case.get("expected_kinds", [])
        ]
        corpus_path.write_text(json.dumps(corpus))
        proc = run([str(BIN), "eval", "--corpus", str(corpus_path)])
        assert_true(proc.returncode == 1, "eval did not fail on detector kind without positive corpus coverage")
        output = json.loads(proc.stdout)
        assert_true(
            "GITHUB_FINE_GRAINED_PAT" in output["coverage"]["quality"].get("missing_positive_kinds", []),
            "eval did not report the missing detector kind",
        )

        quality = asg.evaluate_corpus_quality(
            {},
            {},
            positive_kinds={"TEST_TOKEN"},
            required_positive_kinds={"TEST_TOKEN"},
            detector_hints={},
            positive_kind_inputs={"TEST_TOKEN": ["TEST_TOKEN_VALUE"]},
        )
        assert_true(quality["status"] == "fail", "corpus quality allowed detector without hint")
        assert_true("TEST_TOKEN" in quality["missing_detector_hints"], "corpus quality did not report missing detector hint")

        quality = asg.evaluate_corpus_quality(
            {},
            {},
            positive_kinds={"TEST_TOKEN"},
            required_positive_kinds={"TEST_TOKEN"},
            detector_hints={"TEST_TOKEN": (":",)},
            positive_kind_inputs={"TEST_TOKEN": ["12345:short"]},
        )
        assert_true(quality["status"] == "fail", "corpus quality allowed short literal detector hint")
        assert_true("TEST_TOKEN" in quality["short_detector_hints"], "corpus quality did not report short detector hint")

        quality = asg.evaluate_corpus_quality(
            {},
            {},
            positive_kinds={"TEST_TOKEN"},
            required_positive_kinds={"TEST_TOKEN"},
            detector_hints={"TEST_TOKEN": ("prefix_",)},
            positive_kind_inputs={"TEST_TOKEN": ["token body without prefix"]},
        )
        assert_true(quality["status"] == "fail", "corpus quality allowed positive case that bypasses detector hint")
        assert_true(
            "TEST_TOKEN" in quality["positive_without_detector_hint"],
            "corpus quality did not report positive without detector hint",
        )

        quality = asg.evaluate_corpus_quality(
            {},
            {},
            positive_kinds={"TEST_TOKEN"},
            required_positive_kinds={"TEST_TOKEN"},
            detector_hint_patterns={"TEST_TOKEN": re.compile(r"\d{5}:")},
            positive_kind_inputs={"TEST_TOKEN": ["12345:short"]},
        )
        assert_true(quality["status"] == "pass", "corpus quality rejected detector with pattern hint")


def test_baseline_suppression_no_leak() -> None:
    sample = f"api_key={CANARIES['openai']}"
    with tempfile.TemporaryDirectory(prefix="asg-test-") as temp_dir:
        baseline_path = Path(temp_dir) / "baseline.json"
        proc = run([str(BIN), "baseline-create", "--surface", "text"], input_text=sample)
        assert_true(proc.returncode == 0, f"baseline-create failed: {proc.stderr}")
        assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "baseline-create leaked canary")
        baseline = json.loads(proc.stdout)
        assert_true(baseline["count"] == 1, "baseline-create did not fingerprint finding")
        assert_true(str(baseline["fingerprints"][0]).startswith("asg1:"), "baseline fingerprint missing version prefix")
        baseline_path.write_text(proc.stdout)

        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect", "--baseline", str(baseline_path)], input_text=sample)
        assert_true(proc.returncode == 0, "scan did not suppress baselined finding")

        changed = f"api_key={CANARIES['anthropic']}"
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect", "--baseline", str(baseline_path)], input_text=changed)
        assert_true(proc.returncode == 2, "baseline suppressed a different secret value")

    payload = {"tool_input": {"file_path": str(Path.home() / ".local/share/agent-secret-guard/fingerprint.key")}}
    proc = run([str(FILE_GUARD)], input_text=json.dumps(payload))
    assert_true(proc.returncode == 2, "file-leak-guard did not block ASG fingerprint key")

    for suffix in ("example", "sample", "template", "dist"):
        payload = {"tool_input": {"file_path": f"/tmp/project/.env.{suffix}"}}
        proc = run([str(FILE_GUARD)], input_text=json.dumps(payload))
        assert_true(proc.returncode == 0, f"file-leak-guard blocked .env.{suffix}")

    payload = {"tool_input": {"file_path": "/tmp/project/.env"}}
    proc = run([str(FILE_GUARD)], input_text=json.dumps(payload))
    assert_true(proc.returncode == 2, "file-leak-guard allowed raw .env")


def test_file_path_policy() -> None:
    blocked_paths = [
        str(Path.home() / ".local/share/agent-secret-guard/fingerprint.key"),
        "/tmp/project/.env",
        "/tmp/project/.env.local",
        "/tmp/project/.claude/settings.json",
        "/tmp/project/.claude.json",
        "/tmp/project/.aws/credentials",
        "/tmp/project/.ssh/id_ed25519",
        "/tmp/project/.kube/config",
        "/tmp/project/.config/gcloud/application_default_credentials.json",
        "/tmp/project/.azure/accessTokens.json",
        "/tmp/project/secrets.yaml",
        "/tmp/project/.vault-token",
    ]
    for path in blocked_paths:
        proc = run([str(BIN), "scan", "--surface", "file-path", "--quiet", "--fail-on-detect"], input_text=path)
        assert_true(proc.returncode == 2, f"central file-path policy allowed sensitive path: {path}")
        assert_true(path not in proc.stdout + proc.stderr, "central file-path policy leaked blocked path")

        payload = {"tool_input": {"file_path": path}}
        proc = run([str(FILE_GUARD)], input_text=json.dumps(payload))
        assert_true(proc.returncode == 2, f"file-leak-guard allowed sensitive path: {path}")
        assert_true(path not in proc.stdout + proc.stderr, "file-leak-guard leaked blocked path")

        proc = run([str(ASG_JSON_BLOCK)], input_text=json.dumps(payload))
        assert_true(proc.returncode == 2, f"json-block missed file_path context: {path}")
        assert_true(path not in proc.stdout + proc.stderr, "json-block leaked blocked path")

    for suffix in ("example", "sample", "template", "dist"):
        path = f"/tmp/project/.env.{suffix}"
        payload = {"tool_input": {"file_path": path}}
        proc = run([str(BIN), "scan", "--surface", "file-path", "--quiet", "--fail-on-detect"], input_text=path)
        assert_true(proc.returncode == 0, f"central file-path policy blocked .env.{suffix}")
        proc = run([str(FILE_GUARD)], input_text=json.dumps(payload))
        assert_true(proc.returncode == 0, f"file-leak-guard blocked .env.{suffix}")
        proc = run([str(ASG_JSON_BLOCK)], input_text=json.dumps(payload))
        assert_true(proc.returncode == 0, f"json-block blocked .env.{suffix}")

    infisical_path = "/tmp/project/.infisical.json"
    payload = {"tool_input": {"file_path": infisical_path}}
    proc = run([str(BIN), "scan", "--surface", "file-path", "--quiet", "--fail-on-detect"], input_text=infisical_path)
    assert_true(proc.returncode == 0, "central file-path policy blocked .infisical.json")
    proc = run([str(FILE_GUARD)], input_text=json.dumps(payload))
    assert_true(proc.returncode == 0, "file-leak-guard blocked .infisical.json")
    proc = run([str(ASG_JSON_BLOCK)], input_text=json.dumps(payload))
    assert_true(proc.returncode == 0, "json-block blocked .infisical.json")

    codex_read = {"hook_event_name": "PreToolUse", "tool_name": "Read", "tool_input": {"file_path": "/tmp/project/.env"}}
    proc = run([str(ASG_CODEX_HOOK)], input_text=json.dumps(codex_read))
    output = json.loads(proc.stdout)
    assert_true(output["hookSpecificOutput"]["permissionDecision"] == "deny", "codex file_path pre hook did not deny")

def test_external_scanner_parsers_no_leak() -> None:
    gitleaks = json.dumps(
        [
            {
                "RuleID": "openai-api-key",
                "Description": "OpenAI API key",
                "File": "input.txt",
                "StartLine": 1,
                "Match": f"token={CANARIES['openai']}",
                "Secret": CANARIES["openai"],
                "Fingerprint": "gitleaks-fingerprint",
            }
        ]
    )
    trufflehog = json.dumps(
        {
            "DetectorName": "Github",
            "Verified": True,
            "Raw": CANARIES["github"],
            "Redacted": "ghp_...",
            "SourceMetadata": {"Data": {"Filesystem": {"file": "input.txt", "line": 2}}},
            "Fingerprint": "trufflehog-fingerprint",
        }
    )
    detect_secrets = json.dumps(
        {
            "results": {
                "input.txt": [
                    {
                        "type": "Secret Keyword",
                        "line_number": 3,
                        "hashed_secret": "detect-secrets-hash",
                    }
                ]
            }
        }
    )

    parsed = (
        asg.parse_gitleaks_report(gitleaks)
        + asg.parse_trufflehog_report(trufflehog)
        + asg.parse_detect_secrets_report(detect_secrets)
    )
    rendered = json.dumps(parsed)
    assert_true(len(parsed) == 3, "external scanner parsers lost findings")
    assert_true(CANARIES["openai"] not in rendered, "gitleaks parser leaked raw secret")
    assert_true(CANARIES["github"] not in rendered, "trufflehog parser leaked raw secret")
    assert_true({item["scanner"] for item in parsed} == {"gitleaks", "trufflehog", "detect-secrets"}, "scanner names not preserved")


def test_external_scan_absent_safe() -> None:
    proc = run([str(BIN), "external-scan", "--scanner", "all"], input_text=f"token={CANARIES['openai']}")
    assert_true(proc.returncode == 0, f"external-scan failed: {proc.stderr}")
    assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "external-scan leaked stdin canary")
    output = json.loads(proc.stdout)
    assert_true("skipped" in output and "findings" in output, "external-scan missing structured result")


def test_external_eval_no_leak() -> None:
    proc = run([str(BIN), "external-eval", "--corpus", str(ASG_CORPUS)])
    assert_true(proc.returncode == 0, f"external-eval failed: {proc.stderr}")
    combined = proc.stdout + proc.stderr
    for canary in CANARIES.values():
        assert_true(canary not in combined, "external-eval leaked corpus canary")
    output = json.loads(proc.stdout)
    assert_true(output["ok"] is True, "external-eval reported scanner errors")
    assert_true(output["output"] == "summary", "external-eval default output is not concise summary")
    assert_true("cases" not in output and "disagreements" not in output, "external-eval summary emitted full case matrix")
    assert_true("scanners" in output and "disagreement_count" in output, "external-eval missing comparison summary")
    assert_true("asg" in output and output["asg"]["fn"] == 0, "external-eval summary missing ASG stats")
    assert_true({"gitleaks", "trufflehog", "detect-secrets"}.issubset(output["scanners"]), "external-eval missing scanner stats")
    assert_true("scanner_requirement_gaps" in output, "external-eval missing per-requirement scanner gaps")
    assert_true("external_invocations" in output, "external-eval missing invocation accounting")
    for scanner in ("gitleaks", "trufflehog", "detect-secrets"):
        assert_true(output["external_invocations"].get(scanner, 0) <= 1, f"external-eval did not batch {scanner}")
    assert_true(
        any(gap.get("requirement") == "provider:anthropic" for gap in output["scanner_requirement_gaps"].get("gitleaks", [])),
        "external-eval summary omitted relevant scanner gap",
    )

    summary = asg.summarize_external_eval_result(
        {
            "ok": True,
            "corpus": "synthetic",
            "version": 1,
            "scanners": {},
            "scanner_requirements": {},
            "external_invocations": {},
            "errors": [],
            "cases": [{"label": "positive", "asg_detected": True}],
            "disagreements": [],
        }
    )
    assert_true(summary["asg"]["tp"] == 1 and summary["case_count"] == 1, "external-eval summary helper lost ASG stats")


def test_performance_budget() -> None:
    benign = "INFO build ok path=/Users/example/project file=src/app.ts status=200 duration=12ms\n" * 20000
    timings = []
    for _ in range(3):
        started = time.perf_counter()
        findings = asg.scan_text(benign)
        timings.append(time.perf_counter() - started)
        assert_true(not findings, "large benign scan produced findings")
    assert_true(min(timings) < 0.40, f"large benign scan exceeded budget: {min(timings):.3f}s")

    colon_heavy = "INFO at 12:34:56 worker:api route:account status:200 duration:12ms\n" * 20000
    timings = []
    for _ in range(3):
        started = time.perf_counter()
        findings = asg.scan_text(colon_heavy)
        timings.append(time.perf_counter() - started)
        assert_true(not findings, "colon-heavy benign scan produced findings")
    assert_true(min(timings) < 0.30, f"colon-heavy benign scan exceeded budget: {min(timings):.3f}s")

    secret = "token = " + CANARIES["openai"]
    started = time.perf_counter()
    for _ in range(100):
        findings = asg.scan_text(secret)
        assert_true(any(finding.kind == "OPENAI_PROJECT_KEY" for finding in findings), "small secret scan missed OpenAI key")
    per_scan = (time.perf_counter() - started) / 100
    assert_true(per_scan < 0.005, f"small secret scan exceeded budget: {per_scan:.4f}s")


def test_asg_fast_metadata_does_not_read_open_stdin() -> None:
    proc = subprocess.Popen(
        [str(ASG_FAST), "--version"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    try:
        proc.wait(timeout=1.0)
        stdout, stderr = proc.communicate(timeout=0.2)
    except subprocess.TimeoutExpired:
        proc.kill()
        raise AssertionError("asg-fast --version blocked on open stdin")
    assert_true(proc.returncode == 0, f"asg-fast --version failed: {stderr}")
    assert_true(stdout.startswith("asg-fast "), "asg-fast --version returned unexpected output")

    proc = subprocess.Popen(
        [str(ASG_FAST), "daemon-status"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    try:
        proc.wait(timeout=1.0)
        stdout, stderr = proc.communicate(timeout=0.2)
    except subprocess.TimeoutExpired:
        proc.kill()
        raise AssertionError("asg-fast unsupported daemon command blocked on open stdin")
    assert_true(proc.returncode in (0, 1), f"asg-fast direct CLI command failed with open stdin: {stderr}")
    assert_true(stdout.strip().startswith("{"), "asg-fast direct CLI command returned unexpected output")


def test_asg_fast_wedged_daemon_falls_back_under_deadline() -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        socket_path = str(Path(temp_dir) / "wedged.sock")
        ready = threading.Event()
        stop = threading.Event()

        def wedged_server() -> None:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server:
                server.bind(socket_path)
                server.listen(1)
                ready.set()
                conn, _ = server.accept()
                with conn:
                    stop.wait(2.0)

        thread = threading.Thread(target=wedged_server, daemon=True)
        thread.start()
        assert_true(ready.wait(1.0), "wedged daemon test server did not start")

        env = os.environ.copy()
        env["HOME"] = temp_dir
        env["ASG_AGENT_SECRET_GUARD"] = str(BIN)
        env["ASG_DAEMON_SOCKET"] = socket_path
        env["ASG_FAST_DAEMON_TIMEOUT_MS"] = "150"
        env["ASG_FAST_FALLBACK_TIMEOUT_MS"] = "1000"
        env["ASG_FAST_CIRCUIT_SECONDS"] = "1"

        started = time.perf_counter()
        proc = run(
            [str(ASG_FAST), "scan", "--surface", "bash-command", "--quiet", "--fail-on-detect"],
            input_text="echo hello",
            env=env,
            timeout=2.0,
        )
        elapsed = time.perf_counter() - started
        stop.set()
        assert_true(proc.returncode == 0, f"asg-fast did not fail over from wedged daemon: {proc.stderr}")
        assert_true(elapsed < 1.5, f"asg-fast wedged-daemon failover took too long: {elapsed:.3f}s")

        hook_socket_path = str(Path(temp_dir) / "wedged-hook.sock")
        hook_ready = threading.Event()
        hook_stop = threading.Event()

        def hook_wedged_server() -> None:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server:
                server.bind(hook_socket_path)
                server.listen(1)
                hook_ready.set()
                conn, _ = server.accept()
                with conn:
                    hook_stop.wait(2.0)

        hook_thread = threading.Thread(target=hook_wedged_server, daemon=True)
        hook_thread.start()
        assert_true(hook_ready.wait(1.0), "hook wedged daemon test server did not start")
        hook_env = env.copy()
        hook_env["ASG_DAEMON_SOCKET"] = hook_socket_path

        hook_started = time.perf_counter()
        hook_proc = run(
            [str(ASG_CODEX_HOOK)],
            input_text=json.dumps({"hook_event_name": "UserPromptSubmit", "prompt": "hello"}),
            env=hook_env,
            timeout=2.0,
        )
        hook_elapsed = time.perf_counter() - hook_started
        hook_stop.set()
        assert_true(hook_proc.returncode == 0, f"hook wrapper hung on wedged daemon: {hook_proc.stderr}")
        assert_true(hook_elapsed < 1.5, f"hook wrapper wedged-daemon failover took too long: {hook_elapsed:.3f}s")


def test_asg_fast_stale_socket_and_fallback_positive_detection() -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        socket_path = str(Path(temp_dir) / "stale.sock")
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server:
            server.bind(socket_path)
            server.listen(1)

        env = os.environ.copy()
        env["HOME"] = temp_dir
        env["ASG_AGENT_SECRET_GUARD"] = str(BIN)
        env["ASG_DAEMON_SOCKET"] = socket_path
        env["ASG_FAST_DAEMON_TIMEOUT_MS"] = "150"
        env["ASG_FAST_FALLBACK_TIMEOUT_MS"] = "1000"
        env["ASG_FAST_CIRCUIT_SECONDS"] = "1"

        secret = CANARIES["openai"]
        started = time.perf_counter()
        proc = run(
            [str(ASG_FAST), "scan", "--surface", "bash-command", "--quiet", "--fail-on-detect"],
            input_text="echo " + secret,
            env=env,
            timeout=2.0,
        )
        elapsed = time.perf_counter() - started
        assert_true(proc.returncode == 2, "asg-fast stale-socket fallback missed positive detection")
        assert_true(secret not in proc.stdout + proc.stderr, "asg-fast stale-socket fallback leaked canary")
        assert_true(elapsed < 0.75, f"asg-fast stale-socket fallback took too long: {elapsed:.3f}s")


def test_high_risk_hook_wrappers_fail_closed_on_asg_infrastructure_failure() -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        telemetry_path = Path(temp_dir) / "hook-events.jsonl"
        env = os.environ.copy()
        env["HOME"] = temp_dir
        env["ASG_AGENT_SECRET_GUARD"] = str(Path(temp_dir) / "missing-agent-secret-guard")
        env["ASG_DAEMON_SOCKET"] = str(Path(temp_dir) / "missing.sock")
        env["ASG_FAST_DAEMON_TIMEOUT_MS"] = "100"
        env["ASG_FAST_FALLBACK_TIMEOUT_MS"] = "250"
        env["ASG_FAST_CIRCUIT_SECONDS"] = "1"
        env["ASG_HOOK_TELEMETRY_PATH"] = str(telemetry_path)
        env["ASG_DISABLE_HOOK_TELEMETRY"] = "0"

        codex = run(
            [str(ASG_CODEX_HOOK)],
            input_text=json.dumps({"hook_event_name": "PreToolUse", "tool_name": "Bash", "tool_input": {"command": "true"}}),
            env=env,
            timeout=1.0,
        )
        assert_true(codex.returncode == 0, "codex wrapper failed instead of emitting a deny decision")
        assert_true(
            json.loads(codex.stdout).get("hookSpecificOutput", {}).get("permissionDecision") == "deny",
            "codex wrapper did not fail closed",
        )
        assert_true("asg-recover" in codex.stdout, "codex wrapper omitted recovery command")

        claude = run(
            [str(SECRET_WRAP)],
            input_text=json.dumps({"tool_name": "Bash", "tool_input": {"command": "true"}}),
            env=env,
            timeout=1.0,
        )
        assert_true(claude.returncode == 0, "claude wrapper failed instead of emitting a deny decision")
        claude_output = json.loads(claude.stdout)
        assert_true(
            claude_output.get("hookSpecificOutput", {}).get("permissionDecision") == "deny",
            "claude wrapper did not fail closed",
        )
        assert_true("asg-recover" in claude.stdout, "claude wrapper omitted recovery command")

        cursor = run(
            [str(Path.home() / ".local/bin/asg-cursor-before-shell")],
            input_text=json.dumps({"command": "true"}),
            env=env,
            timeout=1.0,
        )
        assert_true(cursor.returncode == 0, "cursor wrapper failed instead of emitting a deny decision")
        assert_true(json.loads(cursor.stdout).get("permission") == "deny", "cursor wrapper did not fail closed")
        assert_true("asg-recover" in cursor.stdout, "cursor wrapper omitted recovery command")

        claude_post = run(
            [str(SECRET_SCAN)],
            input_text=json.dumps({"tool_name": "Bash", "tool_response": {"stdout": "normal output"}}),
            env=env,
            timeout=1.0,
        )
        assert_true(claude_post.returncode == 0, "claude post wrapper failed instead of suppressing output")
        assert_true(json.loads(claude_post.stdout).get("suppressOutput") is True, "claude post wrapper did not suppress output")
        assert_true("asg-recover" in claude_post.stdout, "claude post wrapper omitted recovery command")
        events = [json.loads(line) for line in telemetry_path.read_text(encoding="utf-8").splitlines()]
        fail_closed_events = [event for event in events if event.get("harness") == "infrastructure" and event.get("event") == "fail-closed"]
        assert_true(len(fail_closed_events) >= 4, "fail-closed wrappers did not record infrastructure telemetry")
        assert_true("hello" not in json.dumps(events) and "true" not in json.dumps(events), "fail-closed telemetry leaked hook payload")


def test_daemon_fast_client() -> None:
    with tempfile.TemporaryDirectory() as temp_dir:
        socket_path = str(Path(temp_dir) / "asg.sock")
        pid_path = str(Path(temp_dir) / "asg.pid")
        env = os.environ.copy()
        env["ASG_DAEMON_SOCKET"] = socket_path
        env["ASG_DAEMON_PID"] = pid_path

        fallback = run([str(ASG_FAST), "scan", "--quiet", "--fail-on-detect"], input_text="normal text", env=env)
        assert_true(fallback.returncode == 0, f"asg-fast fallback failed: {fallback.stderr}")

        weak_entropy = "bare token " + CANARIES["entropy"]
        allowed = run(
            [str(ASG_FAST), "scan", "--surface", "vcs-diff", "--threshold", "0.8", "--quiet", "--fail-on-detect"],
            input_text=weak_entropy,
            env=env,
        )
        assert_true(allowed.returncode == 0, "asg-fast fallback ignored threshold for entropy-only finding")

        start = run([str(BIN), "daemon-start", "--socket", socket_path, "--pid-file", pid_path], env=env)
        if start.returncode != 0:
            try:
                start_payload = json.loads(start.stdout)
            except json.JSONDecodeError:
                start_payload = {}
            if start_payload.get("error") == "daemon unavailable: PermissionError":
                print("SKIP test_daemon_fast_client daemon socket bind unavailable")
                return
            assert_true(False, f"daemon-start failed: stdout={start.stdout} stderr={start.stderr}")
        try:
            status = run([str(BIN), "daemon-status", "--socket", socket_path, "--pid-file", pid_path], env=env)
            assert_true(status.returncode == 0, f"daemon-status failed: {status.stderr}")
            status_payload = json.loads(status.stdout)
            assert_true(status_payload["running"] is True and status_payload["pid"], "daemon did not report running pid")

            secret = "token = " + CANARIES["openai"]
            blocked = run([str(ASG_FAST), "scan", "--quiet", "--fail-on-detect"], input_text=secret, env=env)
            assert_true(blocked.returncode == 2, "asg-fast daemon path missed secret")
            assert_true(CANARIES["openai"] not in blocked.stdout + blocked.stderr, "asg-fast daemon path leaked canary")

            allowed = run(
                [str(ASG_FAST), "scan", "--surface", "vcs-diff", "--threshold", "0.8", "--quiet", "--fail-on-detect"],
                input_text=weak_entropy,
                env=env,
            )
            assert_true(allowed.returncode == 0, "asg-fast daemon path ignored threshold for entropy-only finding")

            redacted = run([str(ASG_FAST), "redact"], input_text=secret, env=env)
            assert_true(redacted.returncode == 0, "asg-fast daemon redact failed")
            assert_true(CANARIES["openai"] not in redacted.stdout, "asg-fast daemon redact leaked canary")
            assert_true("[REDACTED:" in redacted.stdout, "asg-fast daemon redact did not redact")

            help_proc = run([str(ASG_FAST), "--help"], env=env)
            assert_true(help_proc.returncode == 0, f"asg-fast help failed under daemon env: {help_proc.stderr}")
            assert_true("usage: asg-fast" in help_proc.stdout, "asg-fast help returned unexpected output")

            cursor_payload = json.dumps({"event": "beforeSubmitPrompt", "prompt": "normal prompt"})
            cursor_proc = run([str(ASG_FAST), "cursor-hook", "--event", "beforeSubmitPrompt"], input_text=cursor_payload, env=env)
            assert_true(cursor_proc.returncode == 0, f"asg-fast daemon cursor-hook failed: {cursor_proc.stderr}")

            timings = []
            for _ in range(30):
                started = time.perf_counter()
                proc = run([str(ASG_FAST), "scan", "--quiet", "--fail-on-detect"], input_text="normal text", env=env)
                timings.append(time.perf_counter() - started)
                assert_true(proc.returncode == 0, "asg-fast benign daemon scan failed")
            average = sum(timings) / len(timings)
            assert_true(average < 0.200, f"asg-fast daemon path too slow: {average:.4f}s")
        finally:
            run([str(BIN), "daemon-stop", "--socket", socket_path, "--pid-file", pid_path], env=env)


def test_doctor() -> None:
    proc = run([str(BIN), "doctor"])
    assert_true(proc.returncode == 0, f"doctor failed: {proc.stderr}")
    output = json.loads(proc.stdout)
    assert_true(output["ok"] is True, "doctor did not report healthy install")
    assert_true("external_scanners" in output, "doctor missing external scanner inventory")
    assert_true("gitleaks" in output["external_scanners"], "doctor missing gitleaks availability")
    assert_true(output["commands"]["asg-fast"]["available"] is True, "doctor missing asg-fast")
    assert_true(output["commands"]["asg-run"]["available"] is True, "doctor missing asg-run")
    assert_true(output["commands"]["asg-recover"]["available"] is True, "doctor missing asg-recover")
    assert_true(output["commands"]["asg-hook-lib"]["available"] is True, "doctor missing fail-open telemetry helper")
    assert_true(output["commands"]["asg-codex-hook"]["available"] is True, "doctor missing codex hook adapter")
    assert_true(output["fast_client_runtime_probe"]["ok"] is True, "doctor fast-client runtime probe failed")
    fast_probe_names = {case.get("name") for case in output["fast_client_runtime_probe"]["cases"]}
    assert_true("scan-positive-detection" in fast_probe_names, "doctor fast-client probe did not prove positive detection")
    assert_true("claude-pre-missing-daemon-fallback" in fast_probe_names, "doctor fast-client probe did not test claude-pre")
    assert_true(output["daemon_circuit"]["open"] is False, "doctor reported open daemon circuit")
    assert_true("active_harness_coverage" in output, "doctor missing active harness coverage")
    assert_true("hook_observations" in output, "doctor missing hook observation summary")
    assert_true("events" in output["hook_observations"], "doctor hook observation summary missing events")
    for harness in ("claude", "codex", "cursor"):
        assert_true(harness in output["active_harness_coverage"], f"doctor missing {harness} coverage")
    codex = output["active_harness_coverage"]["codex"]
    assert_true(codex["command_health"]["static_failures"] == 0, "doctor found brittle codex hook commands")
    if codex["coverage"] == "covered":
        assert_true(codex["runtime_probe"]["checked"] >= 1, "doctor did not probe codex hooks")
        assert_true(codex["runtime_probe"]["failures"] == [], "doctor found codex hook runtime failures")


def main() -> int:
    tests = [
        test_redaction_no_leaks,
        test_entropy_only_warns_not_blocks,
        test_vercel_deployment_metadata_not_redacted,
        test_db_uri_boundary,
        test_claude_post_adapter,
        test_pre_adapters,
        test_filter_adapter,
        test_path_listing_no_false_redaction,
        test_database_constraint_identifiers_no_false_redaction,
        test_source_code_expression_assignments_no_false_redaction,
        test_vcs_diff_false_positive_regressions,
        test_ref_and_path_slug_redaction_regressions,
        test_provider_coverage_expansion,
        test_http_header_detection,
        test_joined_literal_detection,
        test_static_string_dataflow_detection,
        test_multiline_reconstruction_detection,
        test_escaped_sequence_reconstruction_detection,
        test_encoded_text_reconstruction_detection,
        test_utf16_base64_detection,
        test_display_normalization_detection,
        test_softwrap_reconstruction_detection,
        test_chunked_token_reconstruction_detection,
        test_kinds_are_structured,
        test_git_remote_output_redaction_policy,
        test_shell_secret_reference_not_literal_secret,
        test_generic_json_adapters,
        test_json_key_context,
        test_bash_command_policy,
        test_secret_push_guard_jj_bookmark_scope,
        test_harness_neutral_wrappers,
        test_codex_adapter,
        test_hook_observation_telemetry_no_payload,
        test_installer_manifest,
        test_adapter_proof,
        test_active_harness_coverage,
        test_installer_active_config_apply,
        test_eval_corpus,
        test_eval_corpus_quality_enforced,
        test_baseline_suppression_no_leak,
        test_file_path_policy,
        test_external_scanner_parsers_no_leak,
        test_external_scan_absent_safe,
        test_external_eval_no_leak,
        test_performance_budget,
        test_asg_fast_metadata_does_not_read_open_stdin,
        test_asg_fast_wedged_daemon_falls_back_under_deadline,
        test_asg_fast_stale_socket_and_fallback_positive_detection,
        test_high_risk_hook_wrappers_fail_closed_on_asg_infrastructure_failure,
        test_daemon_fast_client,
        test_doctor,
    ]

    failures: list[str] = []
    for test in tests:
        try:
            test()
            print(f"PASS {test.__name__}")
        except Exception as exc:
            failures.append(f"{test.__name__}: {exc}")
            print(f"FAIL {test.__name__}: {exc}")

    tp, fp, fn, tn = test_metrics()
    precision = tp / (tp + fp) if tp + fp else 1.0
    recall = tp / (tp + fn) if tp + fn else 1.0
    fpr = fp / (fp + tn) if fp + tn else 0.0
    print(f"METRICS tp={tp} fp={fp} fn={fn} tn={tn} precision={precision:.3f} recall={recall:.3f} fpr={fpr:.3f}")

    corpus_proc = run([str(BIN), "eval", "--corpus", str(ASG_CORPUS)])
    if corpus_proc.returncode == 0:
        corpus = json.loads(corpus_proc.stdout)
        metrics = corpus["metrics"]
        print(
            "CORPUS "
            f"tp={metrics['tp']} fp={metrics['fp']} fn={metrics['fn']} tn={metrics['tn']} "
            f"precision={metrics['precision']:.3f} recall={metrics['recall']:.3f} fpr={metrics['fpr']:.3f}"
        )
    else:
        failures.append("eval corpus command failed")

    if failures or precision < 1.0 or recall < 0.95 or fpr > 0.0:
        if failures:
            print("Failures:")
            for failure in failures:
                print(f"  - {failure}")
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
