        "cat > .env <<'EOF'\nHTTP_BEARER_TOKEN=\nHTTP_HOST=0.0.0.0\nHTTP_PORT=8765\nHTTP_ALLOW_LOCALHOST_UNAUTHENTICATED=true\n# AUTH token comment\nEOF",
        "gcloud auth list",
        "gcloud --project sample auth list",
        "gcloud beta auth list",
        "gcloud projects list --format=json",
        "aws sts get-caller-identity",
        "aws ecr describe-repositories --region us-east-1",
        "aws codeartifact list-domains",
        "aws configure list-profiles",
        "aws iam list-access-keys --user-name deploy-user",
        "aws iam list-service-specific-credentials --user-name sofia",
        "gcloud secrets list --project sample-project",
        "gcloud iam service-accounts keys list --iam-account=my-service@example.iam.gserviceaccount.com",
        "az account show",
        "az keyvault secret list --vault-name prod",
        "az keyvault secret list-deleted --vault-name prod",
