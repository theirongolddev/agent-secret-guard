def test_display_normalization_detection() -> None:
    secret = CANARIES["openai"]
    samples = [
        ("ansi-wrapped", "\x1b[32m" + secret + "\x1b[0m"),
        ("ansi-split", secret[:2] + "\x1b[31m" + secret[2:7] + "\x1b[0m" + secret[7:]),
        ("zero-width", "\u200b".join(secret)),
    ]
    allowed_kinds = {"DISPLAY_NORMALIZED_SECRET", "OPENAI_PROJECT_KEY"}
    for label, sample in samples:
        result = json_scan(sample)
        assert_true(result["count"] == 1, f"{label} display-obfuscated secret was missed")
        assert_true(result["findings"][0]["kind"] in allowed_kinds, f"{label} display-obfuscated secret has wrong kind")

        proc = run([str(BIN), "redact"], input_text=sample)
        assert_true(proc.returncode == 0, f"{label} display-obfuscated redact failed: {proc.stderr}")
        assert_true("[REDACTED:" in proc.stdout, f"{label} display-obfuscated secret was not redacted")
        assert_true("sk-" not in proc.stdout and "proj-" not in proc.stdout, f"{label} visible secret prefix leaked")

    benign_samples = [
        "INFO \x1b[32mok\x1b[0m build passed",
        "docs mention zero-width joiner U+200D",
        "The text uses \u200bzero-width space for typography.",
    ]
    for benign in benign_samples:
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
        assert_true(proc.returncode == 0, "benign display formatting was falsely detected")


def test_softwrap_reconstruction_detection() -> None:
    secret = CANARIES["openai"]
    samples = [
        ("newline", secret[:7] + "\n" + secret[7:]),
        ("crlf", secret[:7] + "\r\n" + secret[7:]),
        ("multi-newline", secret[:20] + "\n" + secret[20:40] + "\n" + secret[40:]),
        ("indented", secret[:20] + "\n    " + secret[20:]),
    ]
    for label, sample in samples:
        result = json_scan(sample)
        assert_true(result["count"] == 1, f"{label} soft-wrapped secret was missed")
        assert_true(result["findings"][0]["kind"] == "SOFT_WRAPPED_SECRET", f"{label} soft-wrapped secret has wrong kind")

        proc = run([str(BIN), "redact"], input_text=sample)
        assert_true(proc.returncode == 0, f"{label} soft-wrapped redact failed: {proc.stderr}")
        assert_true("[REDACTED:SOFT_WRAPPED_SECRET]" in proc.stdout, f"{label} soft-wrapped secret was not redacted")
        assert_true("sk-" not in proc.stdout and "proj-" not in proc.stdout, f"{label} visible secret prefix leaked")

    benign_samples = [
        "sk-proj-\nThis line is prose, not token continuation.",
        "Set Sentry vars scoped to Preview\nVITE_PUBLIC_SENTRY_ENVIRONMENT",
        "./.claude-home/\nplugins/cache/\nAGENTS.md",
    ]
    for benign in benign_samples:
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
        assert_true(proc.returncode == 0, "benign multiline text was falsely detected as soft-wrapped secret")


def test_chunked_token_reconstruction_detection() -> None:
    secret = CANARIES["openai"]
    samples = [
        ("space", " ".join(secret[index:index + 12] for index in range(0, len(secret), 12))),
        ("colon", ":".join(secret[index:index + 12] for index in range(0, len(secret), 12))),
        ("tab", "\t".join(secret[index:index + 12] for index in range(0, len(secret), 12))),
    ]
    for label, sample in samples:
        result = json_scan(sample)
        assert_true(result["count"] == 1, f"{label} chunked token was missed")
        assert_true(result["findings"][0]["kind"] == "CHUNKED_SECRET_TOKEN", f"{label} chunked token has wrong kind")

        proc = run([str(BIN), "redact"], input_text=sample)
        assert_true(proc.returncode == 0, f"{label} chunked redact failed: {proc.stderr}")
        assert_true("[REDACTED:CHUNKED_SECRET_TOKEN]" in proc.stdout, f"{label} chunked token was not redacted")
        assert_true("sk-" not in proc.stdout and "proj-" not in proc.stdout, f"{label} visible secret prefix leaked")

    benign_samples = [
        "build id 1234 5678 9012 3456",
        "version sk-proj placeholder documented value",
        "Set Sentry vars scoped to Preview",
        "time 12:34:56 status ok",
    ]
    for benign in benign_samples:
        proc = run([str(BIN), "scan", "--quiet", "--fail-on-detect"], input_text=benign)
        assert_true(proc.returncode == 0, "benign chunked text was falsely detected")


def test_kinds_are_structured() -> None:
    result = json_scan(f"dsn={CANARIES['db']}")
    assert_true(result["count"] == 1, "expected one finding")
    assert_true(result["findings"][0]["kind"] == "CREDENTIAL_URL", "expected credential URL kind")
    assert_true("dsn=" not in json.dumps(result), "findings should not include source text")


def test_git_remote_output_redaction_policy() -> None:
    clean_output = "\n".join(
        [
            "origin\tgit@github.com:example/project.git (fetch)",
            "origin\thttps://github.com/example/project.git (push)",
            "",
        ]
    )
    proc = run([str(BIN), "redact", "--surface", "tool-output"], input_text=clean_output)
    assert_true(proc.returncode == 0, f"clean git remote output redact failed: {proc.stderr}")
    assert_true(proc.stdout == clean_output, "clean git remote output was redacted")

    inline_credential = "not-a-real-inline-token-12345"
    credential_output = f"origin\thttps://x-access-token:{inline_credential}@github.com/example/project.git (fetch)\n"
    proc = run([str(BIN), "redact", "--surface", "tool-output"], input_text=credential_output)
    assert_true(proc.returncode == 0, f"credential git remote output redact failed: {proc.stderr}")
    assert_true(inline_credential not in proc.stdout + proc.stderr, "credential git remote output leaked inline credential")
    assert_true("[REDACTED:CREDENTIAL_URL]" in proc.stdout, "credential git remote output was not redacted")


def test_shell_secret_reference_not_literal_secret() -> None:
    diagnostic_command = "\n".join(
        [
            "TOKEN=$(infisical secrets get CIRCLECI_API_TOKEN --env=dev --plain 2>/dev/null)",
            'PROJ="circleci/project-slug"',
            'WID="ebe029ca-c152-4b4d-a7db-2375b79d4359"',
            'JN=$(curl -s -H "Circle-Token: $TOKEN" "https://circleci.com/api/v2/workflow/$WID/job" 2>/dev/null)',
            'echo "staging-verify = job #$JN"',
            'curl -s -H "Circle-Token: $TOKEN" "https://circleci.com/api/v1.1/project/$PROJ/$JN" 2>/dev/null',
        ]
    )
    proc = run([str(BIN), "scan", "--surface", "bash-command", "--quiet", "--fail-on-detect"], input_text=diagnostic_command)
    assert_true(proc.returncode == 0, "bash command policy blocked secret-by-reference CircleCI diagnostic")
    proc = run([str(BIN), "redact", "--surface", "tool-output"], input_text=diagnostic_command)
    assert_true(proc.returncode == 0, f"tool-output redact failed: {proc.stderr}")
    assert_true("[REDACTED:" not in proc.stdout, "secret-by-reference CircleCI diagnostic was redacted")

    for command in (
        'curl -H "Authorization: Bearer $TOKEN" https://example.test',
        'curl -H "Authorization: Bearer ${TOKEN}" https://example.test',
    ):
        proc = run([str(BIN), "scan", "--surface", "bash-command", "--quiet", "--fail-on-detect"], input_text=command)
        assert_true(proc.returncode == 0, "bash command policy blocked safe auth-header variable reference")


def test_generic_json_adapters() -> None:
    payload = {"tool": {"input": {"apiKey": CANARIES["openai"]}}}
    proc = run([str(BIN), "json-block"], input_text=json.dumps(payload))
    assert_true(proc.returncode == 2, "json-block did not block secret-bearing JSON")
    assert_true(CANARIES["openai"] not in proc.stdout, "json-block leaked JSON canary")

    proc = run([str(BIN), "json-redact"], input_text=json.dumps(payload))
    assert_true(proc.returncode == 0, f"json-redact failed: {proc.stderr}")
    assert_true(CANARIES["openai"] not in proc.stdout, "json-redact leaked JSON canary")
    output = json.loads(proc.stdout)
    assert_true(output["redacted"]["tool"]["input"]["apiKey"].startswith("[REDACTED:"), "json-redact did not redact nested value")

    multi_payload = {"a": CANARIES["openai"], "b": CANARIES["github"]}
    proc = run([str(BIN), "json-block"], input_text=json.dumps(multi_payload))
    output = json.loads(proc.stdout)
    assert_true(output["count"] == 2, "json-block undercounted findings across fields")

    key_payload = {CANARIES["openai"]: "value"}
    proc = run([str(BIN), "json-block"], input_text=json.dumps(key_payload))
    assert_true(proc.returncode == 2, "json-block missed secret-bearing object key")
    assert_true(CANARIES["openai"] not in proc.stdout + proc.stderr, "json-block leaked object-key canary")
    output = json.loads(proc.stdout)
    assert_true("OPENAI_PROJECT_KEY" in output["kinds"], "json-block reported wrong kind for object-key secret")

    proc = run([str(BIN), "json-redact"], input_text=json.dumps(key_payload))
    assert_true(proc.returncode == 0, f"json-redact object-key failed: {proc.stderr}")
    assert_true(CANARIES["openai"] not in proc.stdout, "json-redact leaked object-key canary")
    output = json.loads(proc.stdout)
    redacted_keys = list(output["redacted"].keys())
    assert_true(redacted_keys and redacted_keys[0].startswith("[REDACTED:"), "json-redact did not redact secret-bearing object key")


def test_json_key_context() -> None:
    payload = {"auth": {"apiKey": CANARIES["assignment"], "nested": [{"clientSecret": "Cl13nt-Secret_Value-ABCDE"}]}}
    proc = run([str(BIN), "json-block"], input_text=json.dumps(payload))
    assert_true(proc.returncode == 2, "json-block missed sensitive key-context value")
    assert_true(CANARIES["assignment"] not in proc.stdout + proc.stderr, "json-block leaked key-context canary")
    output = json.loads(proc.stdout)
    assert_true("SENSITIVE_JSON_VALUE" in output["kinds"], "json-block reported wrong kind for key-context secret")

    proc = run([str(BIN), "json-redact"], input_text=json.dumps(payload))
    assert_true(proc.returncode == 0, f"json-redact failed: {proc.stderr}")
    assert_true(CANARIES["assignment"] not in proc.stdout, "json-redact leaked key-context canary")
    output = json.loads(proc.stdout)
    assert_true(output["redacted"]["auth"]["apiKey"].startswith("[REDACTED:"), "json-redact missed key-context apiKey")
    assert_true(output["redacted"]["auth"]["nested"][0]["clientSecret"].startswith("[REDACTED:"), "json-redact missed nested key-context clientSecret")

    benign = {"apiKey": "abcdefghijklmnop", "clientSecret": "process.env.CLIENT_SECRET", "password": "changeme"}
    proc = run([str(BIN), "json-block"], input_text=json.dumps(benign))
    assert_true(proc.returncode == 0, "json-block false-positive on benign sensitive-key placeholders")

    key_id = ascii_text([112, 114, 105, 118, 97, 116, 101, 95, 107, 101, 121, 95, 105, 100])
    key_name = ascii_text([115, 101, 99, 114, 101, 116, 95, 110, 97, 109, 101])
    identifier_payload = {
        key_id: "0123456789abcdef0123456789abcdef01234567",
        key_name: "prod-api-key",
    }
    proc = run([str(BIN), "json-block"], input_text=json.dumps(identifier_payload))
    assert_true(proc.returncode == 0, "json-block false-positive on sensitive identifier keys")

    proc = run(
        [str(BIN), "scan", "--quiet", "--fail-on-detect"],
        input_text=f"{key_id}=0123456789abcdef0123456789abcdef01234567",
    )
    assert_true(proc.returncode == 0, "assignment scan false-positive on private key identifier")

    pem_header = ascii_text([45, 45, 45, 45, 45, 66, 69, 71, 73, 78, 32, 80, 82, 73, 86, 65, 84, 69, 32, 75, 69, 89, 45, 45, 45, 45, 45])
    pem_footer = ascii_text([45, 45, 45, 45, 45, 69, 78, 68, 32, 80, 82, 73, 86, 65, 84, 69, 32, 75, 69, 89, 45, 45, 45, 45, 45])
    key_value = pem_header + "\nMIIEvSyntheticServiceAccountPrivateKeyBodyForDetector\n" + pem_footer + "\n"
    key_name = ascii_text([112, 114, 105, 118, 97, 116, 101, 95, 107, 101, 121])
    payload = {key_id: "0123456789abcdef0123456789abcdef01234567", key_name: key_value}
    proc = run([str(BIN), "json-block"], input_text=json.dumps(payload))
    assert_true(proc.returncode == 2, "json-block missed escaped private-key JSON")
    output = json.loads(proc.stdout)
    assert_true(output["count"] == 1, "json-block should suppress key id and report only private key material")
    assert_true(output["kinds"] == ["PRIVATE_KEY_BLOCK"], "json-block reported wrong kind for escaped private-key JSON")


def test_bash_command_policy() -> None:
    blocked_commands = [
        "env",
        "printenv",
        "ps aux",
        "cat ~/.aws/credentials",
        f"curl -H 'Authorization: Bearer {CANARIES['circleci_project_api']}' https://example.test",
        "curl -u \"$API_USER:$API_TOKEN\" https://example.test",
        "wget --password=\"$DOWNLOAD_TOKEN\" https://example.test/file",
        "gcloud auth print-access-token",
