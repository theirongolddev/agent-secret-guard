        kind = kind.split(":", 1)[0]
        assert_true(result["count"] == 1, f"{kind} sample produced unexpected finding count")
        assert_true(result["findings"][0]["kind"] == kind, f"{kind} sample has wrong kind")

    result = json_scan(f"SOPS_AGE_PQ_KEY={CANARIES['age_pq']}")
    assert_true(result["count"] == 1, "AGE_SECRET_KEY PQ sample produced unexpected finding count")
    assert_true(result["findings"][0]["kind"] == "AGE_SECRET_KEY", "AGE_SECRET_KEY PQ sample has wrong kind")

