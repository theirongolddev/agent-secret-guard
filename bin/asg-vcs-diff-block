#!/bin/bash
# Generic harness adapter: read a VCS diff from stdin and block if it contains
# credible secret material. The diff is never echoed.
set -euo pipefail
. "{{ASG_HOME}}/.local/bin/asg-hook-lib"

set +e
"{{ASG_HOME}}/.local/bin/asg-fast" scan --surface vcs-diff --quiet --fail-on-detect
STATUS=$?
set -e

if [[ "$STATUS" -eq 0 ]]; then
  exit 0
fi

if [[ "$STATUS" -ne 2 ]]; then
  asg_fail_closed_stderr generic
fi

printf '%s\n' 'Blocked VCS operation: potential secret material detected in diff. Diff omitted.' >&2
exit 2
