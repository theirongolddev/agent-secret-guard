#!/bin/bash
# Compatibility adapter: block outbound tool calls carrying secrets.
set -euo pipefail
. "{{ASG_HOME}}/.local/bin/asg-hook-lib"
if OUTPUT=$("{{ASG_HOME}}/.local/bin/asg-fast" claude-pre --surface outbound "$@" 2>/dev/null); then
  printf '%s\n' "$OUTPUT"
  exit 0
fi
asg_claude_pretool_fail_closed claude
