#!/bin/bash
# Compatibility adapter: block URL fetches carrying embedded secrets.
set -euo pipefail
. "/Users/tayloreernisse/.local/bin/asg-hook-lib"
if OUTPUT=$("/Users/tayloreernisse/.local/bin/asg-fast" claude-pre --surface url "$@" 2>/dev/null); then
  printf '%s\n' "$OUTPUT"
  exit 0
fi
asg_claude_pretool_fail_closed claude
