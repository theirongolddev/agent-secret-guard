#!/bin/bash
# Generic harness adapter: read JSON from stdin, scan all string values, exit 2
# on detection without printing source content.
set -euo pipefail
. "/Users/tayloreernisse/.local/bin/asg-hook-lib"
set +e
"/Users/tayloreernisse/.local/bin/asg-fast" json-block "$@"
STATUS=$?
set -e
if [[ "$STATUS" -eq 2 ]]; then
  exit 2
fi
if [[ "$STATUS" -ne 0 ]]; then
  asg_fail_closed_stderr generic
fi
exit 0
