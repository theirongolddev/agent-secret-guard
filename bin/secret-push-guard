#!/bin/bash
# PreToolUse adapter: block git/jj pushes when the outgoing diff contains
# secrets. Detection is delegated to Agent Secret Guard.
set -euo pipefail
. "{{ASG_HOME}}/.local/bin/asg-hook-lib"

JQ="/usr/bin/jq"
if [[ ! -x "$JQ" ]]; then
  asg_fail_closed_stderr claude
fi

INPUT=$(/bin/cat)
COMMAND=$(printf '%s' "$INPUT" | "$JQ" -r '.tool_input.command // ""' 2>/dev/null || true)

deny_push() {
  local reason="$1"
  "$JQ" -n \
    --arg reason "$reason" \
    '{
      hookSpecificOutput: {
        hookEventName: "PreToolUse",
        permissionDecision: "deny",
        permissionDecisionReason: $reason
      }
    }'
  exit 0
}

if ! printf '%s' "$COMMAND" | /usr/bin/grep -qE '(^|[[:space:];&|])((git[[:space:]]+push)|(jj[[:space:]]+git[[:space:]]+push))([[:space:]]|$)'; then
  echo '{"continue": true}'
  exit 0
fi

find_repo_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.jj" ]] || [[ -d "$dir/.git" ]] || [[ -f "$dir/.git" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir=$(/usr/bin/dirname "$dir")
  done
  return 1
}

REPO_ROOT=$(find_repo_root || true)
if [[ -z "$REPO_ROOT" ]]; then
  deny_push "Blocked push: repository context could not be verified, so outgoing content cannot be scanned for secrets."
fi

cd "$REPO_ROOT" || deny_push "Blocked push: repository root could not be entered, so outgoing content cannot be scanned for secrets."

derive_jj_scan_revset() {
  ASG_PUSH_COMMAND="$COMMAND" /usr/bin/python3 - <<'PY'
import os
import re
import shlex
import sys

command = os.environ.get("ASG_PUSH_COMMAND", "")
try:
    words = shlex.split(command)
except ValueError:
    words = command.split()

def safe_revset_atom(value: str) -> bool:
    return bool(re.fullmatch(r"[A-Za-z0-9_@./:+-]+", value))

for index in range(max(0, len(words) - 2)):
    if words[index:index + 3] != ["jj", "git", "push"]:
        continue
    args = words[index + 3:]
    if "--all" in args:
        print("remote_bookmarks()..bookmarks()")
        sys.exit(0)

    target = ""
    for arg_index, arg in enumerate(args):
        next_arg = args[arg_index + 1] if arg_index + 1 < len(args) else ""
        if arg in ("-b", "--bookmark") and next_arg:
            target = next_arg
            break
        if arg.startswith("--bookmark="):
            target = arg.split("=", 1)[1]
            break
        if arg.startswith("-b") and len(arg) > 2:
            target = arg[2:]
            break
        if arg in ("-r", "--revision", "--revisions") and next_arg:
            target = next_arg
            break
        if arg.startswith("--revision=") or arg.startswith("--revisions="):
            target = arg.split("=", 1)[1]
            break

    if target and safe_revset_atom(target):
        print(f"remote_bookmarks()..{target}")
        sys.exit(0)
    if target:
        sys.exit(2)
    print("remote_bookmarks()..@")
    sys.exit(0)

sys.exit(1)
PY
}

DIFF_CONTENT=""
if [[ -d ".jj" ]]; then
  if ! command -v jj >/dev/null 2>&1; then
    deny_push "Blocked push: jj repository detected but jj is not available for outgoing diff scanning."
  fi
  JJ_SCAN_REVSET=$(derive_jj_scan_revset || true)
  if [[ -z "$JJ_SCAN_REVSET" ]]; then
    deny_push "Blocked push: jj push target could not be parsed, so outgoing content cannot be scanned precisely."
  fi
  DIFF_CONTENT="$(
    {
      jj log -r "$JJ_SCAN_REVSET" --no-graph -T 'description ++ "\n"' 2>/dev/null || true
      jj diff -r "$JJ_SCAN_REVSET" 2>/dev/null || true
    }
  )"
elif [[ -d ".git" ]] || [[ -f ".git" ]]; then
  if ! command -v git >/dev/null 2>&1; then
    deny_push "Blocked push: git repository detected but git is not available for outgoing diff scanning."
  fi
  CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "main")
  UPSTREAM=$(git rev-parse --abbrev-ref "@{upstream}" 2>/dev/null || echo "origin/${CURRENT_BRANCH}")
  DIFF_CONTENT="$(
    {
      git log "${UPSTREAM}..HEAD" --pretty=format:"%B" 2>/dev/null || true
      git diff "${UPSTREAM}..HEAD" 2>/dev/null || true
    }
  )"
fi

if [[ -z "$DIFF_CONTENT" ]] || [[ ${#DIFF_CONTENT} -lt 10 ]]; then
  echo '{"continue": true}'
  exit 0
fi

PUSH_BLOCK_THRESHOLD="${ASG_PUSH_BLOCK_THRESHOLD:-0.8}"
set +e
printf '%s' "$DIFF_CONTENT" | "$HOME/.local/bin/asg-fast" scan --surface vcs-diff --threshold "$PUSH_BLOCK_THRESHOLD" --quiet --fail-on-detect
STATUS=$?
set -e

if [[ "$STATUS" -eq 0 ]]; then
  echo '{"continue": true}'
  exit 0
fi

if [[ "$STATUS" -ne 2 ]]; then
  deny_push "Blocked push: Agent Secret Guard infrastructure unavailable, so outgoing content cannot be scanned for secrets. Run {{ASG_HOME}}/.local/bin/asg-recover, then retry. If recovery reports ok=false, run {{ASG_HOME}}/.local/bin/agent-secret-guard doctor."
fi

deny_push "Blocked push: potential secret content detected in outgoing commits or diff. Findings omitted to avoid logging secrets."
