            "beforeShellExecution": [
                {"command": str(BIN / "asg-cursor-before-shell"), "failClosed": False, "timeout": 2}
            ],
            "beforeMCPExecution": [
                {"command": str(BIN / "asg-cursor-before-mcp"), "failClosed": False, "timeout": 2}
            ],
            "beforeReadFile": [
                {"command": str(BIN / "asg-cursor-before-read"), "failClosed": False, "timeout": 2}
            ],
            "postToolUse": [
                {"command": str(BIN / "asg-cursor-posttooluse"), "matcher": ".*", "failClosed": False, "timeout": 2}
            ],
            "afterShellExecution": [
                {"command": str(BIN / "asg-cursor-after-shell"), "failClosed": False, "timeout": 2}
