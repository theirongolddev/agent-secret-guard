#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import argparse
import shutil
import stat
import subprocess
import sys
import tempfile
import time
from pathlib import Path


HOME = Path.home()
BIN = HOME / ".local/bin"
LIB = HOME / ".local/lib"
SHARE = HOME / ".local/share/agent-secret-guard"
MANIFEST = SHARE / "install-manifest.json"
CORPUS = SHARE / "eval-corpus.json"
FAST_CLIENT_SRC = HOME / ".local/src/agent-secret-guard/asg_fast.c"
DEFAULT_CURSOR_CONFIG = str(HOME / ".cursor/hooks.json")

sys.path.insert(0, str(LIB))
try:
    import agent_secret_guard as asg
except Exception:  # pragma: no cover - installer reports this in the manifest.
    asg = None


COMMANDS = [
    "agent-secret-guard",
    "asg-fast",
    "agent-secret-guard-tests",
    "asg-json-block",
    "asg-json-redact",
    "asg-stream-redact",
    "asg-bash-command-block",
    "asg-vcs-diff-block",
    "asg-run",
    "asg-recover",
    "asg-hook-lib",
    "asg-codex-hook",
    "asg-cursor-before-prompt",
    "asg-cursor-pretooluse",
    "asg-cursor-before-shell",
    "asg-cursor-before-mcp",
    "asg-cursor-before-read",
    "asg-cursor-posttooluse",
    "asg-cursor-after-shell",
    "asg-cursor-after-mcp",
    "asg-cursor-after-file-edit",
    "asg-cursor-after-agent-response",
    "asg-cursor-after-agent-thought",
    "secret-scan",
    "secret-filter",
    "secret-wrap",
    "secret-mcp-guard",
    "secret-url-guard",
    "secret-push-guard",
    "cmd-leak-guard",
    "file-leak-guard",
    "infisical-guard",
]

HARNESS_COMMANDS = ["claude", "codex", "cursor"]
EXTERNAL_SCANNERS = ["gitleaks", "trufflehog", "detect-secrets"]


def executable(path: Path) -> bool:
    return path.exists() and os.access(path, os.X_OK)


def build_fast_client() -> dict[str, object]:
    cc = shutil.which("cc") or shutil.which("clang") or shutil.which("gcc")
    target = BIN / "asg-fast"
    result: dict[str, object] = {
        "source": str(FAST_CLIENT_SRC),
        "target": str(target),
        "compiler": cc,
        "built": False,
        "available": executable(target),
    }
    if not cc or not FAST_CLIENT_SRC.exists():
        return result
    proc = subprocess.run(
        [cc, "-O2", "-Wall", "-Wextra", "-o", str(target), str(FAST_CLIENT_SRC)],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    if proc.returncode == 0:
        target.chmod(0o755)
        result["built"] = True
        result["available"] = executable(target)
    return result


def build_claude_hooks() -> dict[str, object]:
    return {
        "hooks": {
            "PreToolUse": [
                {
                    "matcher": "Bash",
                    "hooks": [
                        {"type": "command", "command": str(BIN / "cmd-leak-guard")},
                        {"type": "command", "command": str(BIN / "secret-wrap")},
                        {"type": "command", "command": str(BIN / "infisical-guard")},
                        {"type": "command", "command": str(BIN / "secret-push-guard")},
                    ],
                },
                {
                    "matcher": "Read",
                    "hooks": [
                        {"type": "command", "command": str(BIN / "file-leak-guard")},
                    ],
                },
                {
                    "matcher": "WebFetch|WebSearch",
                    "hooks": [
                        {"type": "command", "command": str(BIN / "secret-url-guard")},
                    ],
                },
                {
                    "matcher": "mcp__.*",
                    "hooks": [
                        {"type": "command", "command": str(BIN / "secret-mcp-guard")},
                    ],
                },
            ],
            "PostToolUse": [
                {
                    "matcher": "*",
                    "hooks": [
                        {"type": "command", "command": str(BIN / "secret-scan")},
                    ],
                }
            ],
        }
    }


