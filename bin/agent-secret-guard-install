def write_snippets() -> dict[str, str]:
    claude_hooks = build_claude_hooks()
    claude_path = SHARE / "claude-settings-hooks.json"
    claude_path.write_text(json.dumps(claude_hooks, indent=2, sort_keys=True) + "\n")

    codex_hooks = build_codex_hooks()
    codex_path = SHARE / "codex-hooks.json"
    codex_path.write_text(json.dumps(codex_hooks, indent=2, sort_keys=True) + "\n")

    cursor_hooks = build_cursor_hooks()
    cursor_path = SHARE / "cursor-hooks.json"
    cursor_path.write_text(json.dumps(cursor_hooks, indent=2, sort_keys=True) + "\n")

    return {
        "claude_settings_hooks_json": str(claude_path),
        "codex_hooks_json": str(codex_path),
        "cursor_hooks_json": str(cursor_path),
    }


def runtime_probe_failed(probe: object, *, require_checked: bool = True) -> bool:
    if not isinstance(probe, dict):
        return True
    if probe.get("error"):
        return True
    if probe.get("failures"):
        return True
    if require_checked and int(probe.get("checked") or 0) < 1:
        return True
    return False


def hook_commands(value: object) -> list[str]:
    commands: list[str] = []
    if isinstance(value, dict):
        for key, child in value.items():
            if key == "command" and isinstance(child, str):
                commands.append(child)
            else:
                commands.extend(hook_commands(child))
    elif isinstance(value, list):
        for child in value:
            commands.extend(hook_commands(child))
    return commands


def command_has_marker(value: object, markers: tuple[str, ...]) -> bool:
    return any(marker in command for command in hook_commands(value) for marker in markers)


def remove_marked_hooks(entries: list[object], markers: tuple[str, ...]) -> tuple[list[object], int, int]:
    kept_entries: list[object] = []
    removed_hooks = 0
    removed_groups = 0
    for entry in entries:
        if isinstance(entry, dict) and isinstance(entry.get("hooks"), list):
            filtered_hooks = [hook for hook in entry["hooks"] if not command_has_marker(hook, markers)]
            removed_hooks += len(entry["hooks"]) - len(filtered_hooks)
            if filtered_hooks:
                next_entry = dict(entry)
                next_entry["hooks"] = filtered_hooks
                kept_entries.append(next_entry)
            else:
                removed_groups += 1
            continue
        if command_has_marker(entry, markers):
            removed_hooks += len(hook_commands(entry)) or 1
            removed_groups += 1
            continue
        kept_entries.append(entry)
    return kept_entries, removed_hooks, removed_groups


def load_config(path: Path) -> dict[str, object]:
    if not path.exists():
        return {}
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise ValueError("top-level JSON must be an object")
    return data


def merge_hook_snippet(base: dict[str, object], snippet: dict[str, object], markers: tuple[str, ...]) -> tuple[dict[str, object], dict[str, object]]:
    merged = json.loads(json.dumps(base))
    hooks = merged.setdefault("hooks", {})
    if not isinstance(hooks, dict):
        hooks = {}
        merged["hooks"] = hooks

    snippet_hooks = snippet.get("hooks", {})
    if not isinstance(snippet_hooks, dict):
        return merged, {"events": {}, "changed": False}

    event_summary: dict[str, object] = {}
    changed = False
    for event, entries in snippet_hooks.items():
        canonical_entries = entries if isinstance(entries, list) else []
        existing = hooks.get(event, [])
        existing_entries = existing if isinstance(existing, list) else []
        kept_entries, removed_hooks, removed_groups = remove_marked_hooks(existing_entries, markers)
        next_entries = kept_entries + canonical_entries
        if next_entries != existing_entries:
            changed = True
        hooks[event] = next_entries
        event_summary[str(event)] = {
            "existing_groups": len(existing_entries),
            "removed_asg_groups": removed_groups,
            "removed_asg_hooks": removed_hooks,
            "installed_asg_groups": len(canonical_entries),
        }

    return merged, {"events": event_summary, "changed": changed}


def backup_config(path: Path) -> str | None:
    if not path.exists():
        return None
    stamp = time.strftime("%Y%m%d-%H%M%S")
    backup = path.with_name(f"{path.name}.asg-backup-{stamp}")
    shutil.copy2(path, backup)
    backup.chmod(0o600)
    return str(backup)


def write_config_atomic(path: Path, data: dict[str, object]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_name(f".{path.name}.asg-tmp-{os.getpid()}")
    temp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    temp.chmod(0o600)
    os.replace(temp, path)


def write_text_atomic(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_name(f".{path.name}.asg-tmp-{os.getpid()}")
    temp.write_text(text, encoding="utf-8")
    temp.chmod(0o600)
    os.replace(temp, path)


def runtime_probe_config_data(data: dict[str, object], harness: str) -> dict[str, object]:
    if not asg:
        return {"error": "agent_secret_guard import failed"}
    SHARE.mkdir(parents=True, exist_ok=True)
    temp_path: Path | None = None
    try:
        fd, raw_path = tempfile.mkstemp(prefix=f".{harness}-active-probe-", suffix=".json", dir=str(SHARE))
        temp_path = Path(raw_path)
        try:
            os.write(fd, (json.dumps(data, indent=2, sort_keys=True) + "\n").encode("utf-8"))
        finally:
            os.close(fd)
        temp_path.chmod(0o600)
        if harness == "claude":
            return asg.claude_hook_runtime_probe(temp_path)
        if harness == "codex":
            return asg.codex_hook_runtime_probe(temp_path)
        if harness == "cursor":
            return asg.cursor_hook_runtime_probe(temp_path)
        return {"error": "unsupported harness"}
    except Exception as exc:
        return {"error": f"{exc.__class__.__name__}: {exc}"}
    finally:
        if temp_path is not None:
            try:
                temp_path.unlink()
            except OSError:
                pass


def install_one_config(
    path: Path,
    snippet: dict[str, object],
    markers: tuple[str, ...],
    *,
    apply: bool,
    harness: str = "",
    probe_before_write: bool = False,
) -> dict[str, object]:
    try:
        base = load_config(path)
        merged, summary = merge_hook_snippet(base, snippet, markers)
    except Exception as exc:
        return {
            "path": str(path),
            "ok": False,
            "applied": False,
            "changed": False,
            "error": f"{exc.__class__.__name__}: {exc}",
        }

    changed = bool(summary["changed"])
    runtime_probe = None
    if probe_before_write:
        runtime_probe = runtime_probe_config_data(merged, harness)
        if runtime_probe_failed(runtime_probe):
            return {
                "path": str(path),
                "ok": False,
                "applied": False,
                "changed": changed,
                "error": "runtime probe failed",
                "runtime_probe": runtime_probe,
                "summary": summary,
            }

    backup_path = None
    if apply and changed:
        backup_path = backup_config(path)
        write_config_atomic(path, merged)

    return {
        "path": str(path),
        "ok": True,
        "applied": bool(apply and changed),
        "changed": changed,
        "backup_path": backup_path,
        "runtime_probe": runtime_probe,
        "summary": summary,
    }


def install_plugin_file(path: Path, content: str, *, apply: bool) -> dict[str, object]:
    try:
        current = path.read_text(encoding="utf-8") if path.exists() else ""
    except OSError as exc:
        return {
            "path": str(path),
            "ok": False,
            "applied": False,
            "changed": False,
            "error": f"{exc.__class__.__name__}: {exc}",
        }

    changed = current != content
    backup_path = None
    if apply and changed:
        backup_path = backup_config(path)
        write_text_atomic(path, content)

    return {
        "path": str(path),
        "ok": True,
        "applied": bool(apply and changed),
        "changed": changed,
        "backup_path": backup_path,
        "summary": {
            "plugin": "agent-secret-guard",
            "events": ["tool.execute.before", "tool.execute.after"],
        },
    }


def should_install_cursor(path: Path, default_path: Path) -> bool:
    cursor_app = Path("/Applications/Cursor.app")
    return path != default_path or path.exists() or cursor_app.exists() or bool(shutil.which("cursor") or shutil.which("cursor-agent"))


def install_active_configs(args: argparse.Namespace) -> dict[str, object]:
    apply = bool(args.apply and not args.dry_run)
    claude_path = Path(args.claude_config).expanduser()
    codex_path = Path(args.codex_config).expanduser()
    cursor_path = Path(args.cursor_config).expanduser()
    cursor_default_path = Path(DEFAULT_CURSOR_CONFIG).expanduser()

    cursor_result: dict[str, object]
    if should_install_cursor(cursor_path, cursor_default_path):
        cursor_result = install_one_config(
            cursor_path,
            build_cursor_hooks(),
            ("cursor-hook", "asg-cursor-"),
            apply=apply,
            harness="cursor",
            probe_before_write=True,
        )
    else:
        cursor_result = {
            "path": str(cursor_path),
            "ok": True,
            "applied": False,
            "changed": False,
            "mode": "harness-unavailable",
            "summary": {"reason": "cursor/cursor-agent not found and no existing Cursor hook config"},
        }

    results = {
        "mode": "apply" if apply else "dry-run",
        "claude": install_one_config(
            claude_path,
            build_claude_hooks(),
            tuple(asg.CLAUDE_HOOK_MARKERS["PreToolUse"]) + tuple(asg.CLAUDE_HOOK_MARKERS["PostToolUse"])
            if asg
            else ("secret-wrap", "secret-scan"),
            apply=apply,
            harness="claude",
            probe_before_write=True,
        ),
        "codex": install_one_config(
            codex_path,
            build_codex_hooks(),
            ("asg-codex-hook",),
            apply=apply,
            harness="codex",
            probe_before_write=True,
        ),
        "cursor": cursor_result,
    }
    return results


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Install Agent Secret Guard binaries, snippets, and optional active hook configs.")
    parser.add_argument("--apply", action="store_true", help="merge ASG hooks into active Claude/Codex/Cursor user configs")
    parser.add_argument("--dry-run", action="store_true", help="report active-config changes without writing them")
    parser.add_argument("--claude-config", default=str(HOME / ".claude/settings.json"))
    parser.add_argument("--codex-config", default=str(HOME / ".codex/hooks.json"))
    parser.add_argument("--cursor-config", default=DEFAULT_CURSOR_CONFIG)
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    SHARE.mkdir(parents=True, exist_ok=True)
    fast_client = build_fast_client()

    installed = {}
    for command in COMMANDS:
        path = BIN / command
        if path.exists():
            mode = path.stat().st_mode
            path.chmod(mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
        installed[command] = {"path": str(path), "present": executable(path)}

    core = LIB / "agent_secret_guard.py"
    if core.exists():
        mode = core.stat().st_mode
        core.chmod(mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)

    harnesses = {
        name: {"path": shutil.which(name), "available": bool(shutil.which(name))}
        for name in HARNESS_COMMANDS
    }
    if asg:
        harnesses["cursor"] = asg.cursor_installation_status()
    external_scanners = {
        name: {"path": shutil.which(name), "available": bool(shutil.which(name))}
        for name in EXTERNAL_SCANNERS
    }
    snippets = write_snippets()
    generated_paths = {
        "claude": Path(snippets["claude_settings_hooks_json"]),
        "codex": Path(snippets["codex_hooks_json"]),
        "cursor": Path(snippets["cursor_hooks_json"]),
    }
    coverage_paths = {
        "claude": Path(args.claude_config).expanduser(),
        "codex": Path(args.codex_config).expanduser(),
        "cursor": Path(args.cursor_config).expanduser(),
    }
    fast_runtime_probe = asg.fast_client_runtime_probe() if asg else {"error": "agent_secret_guard import failed"}
    generated_claude_probe = asg.claude_hook_runtime_probe(generated_paths["claude"]) if asg else {"error": "agent_secret_guard import failed"}
    generated_codex_probe = asg.codex_hook_runtime_probe(generated_paths["codex"]) if asg else {"error": "agent_secret_guard import failed"}
    generated_cursor_probe = asg.cursor_hook_runtime_probe(generated_paths["cursor"]) if asg else {"error": "agent_secret_guard import failed"}
    probe_blockers = []
    if runtime_probe_failed(fast_runtime_probe):
        probe_blockers.append("fast-client-runtime")
    if runtime_probe_failed(generated_claude_probe):
        probe_blockers.append("generated-claude-runtime")
    if runtime_probe_failed(generated_codex_probe):
        probe_blockers.append("generated-codex-runtime")
    if runtime_probe_failed(generated_cursor_probe):
        probe_blockers.append("generated-cursor-runtime")
    if args.apply and probe_blockers:
        active_config_install = {
            "mode": "blocked-runtime-probe",
            "ok": False,
            "applied": False,
            "changed": False,
            "blockers": probe_blockers,
        }
    else:
        active_config_install = install_active_configs(args) if args.apply or args.dry_run else {"mode": "not-requested"}
    generated_coverage = asg.active_harness_coverage(generated_paths) if asg else {"error": "agent_secret_guard import failed"}
    active_coverage = asg.active_harness_coverage(coverage_paths) if asg else {"error": "agent_secret_guard import failed"}
    runtime_probe = (
        {
            "fast_client": fast_runtime_probe,
            "active_claude": asg.claude_hook_runtime_probe(coverage_paths["claude"]),
            "generated_claude": generated_claude_probe,
            "active_codex": asg.codex_hook_runtime_probe(coverage_paths["codex"]),
            "generated_codex": generated_codex_probe,
            "active_cursor": asg.cursor_hook_runtime_probe(coverage_paths["cursor"]),
            "generated_cursor": generated_cursor_probe,
        }
        if asg
        else {"error": "agent_secret_guard import failed"}
    )

    manifest = {
        "engine": str(BIN / "agent-secret-guard"),
        "library": str(core),
        "share": str(SHARE),
        "eval_corpus": {"path": str(CORPUS), "present": CORPUS.exists()},
        "commands": installed,
        "harnesses": harnesses,
        "external_scanners": external_scanners,
        "fast_client": fast_client,
        "active_config_install": active_config_install,
        "active_harness_coverage": active_coverage,
        "generated_harness_coverage": generated_coverage,
        "runtime_probe": runtime_probe,
        "adapter_contract": {
            "fast_client": str(BIN / "asg-fast"),
            "json_block": str(BIN / "asg-json-block"),
            "json_redact": str(BIN / "asg-json-redact"),
            "stream_redact": str(BIN / "asg-stream-redact"),
            "bash_command_block": str(BIN / "asg-bash-command-block"),
            "vcs_diff_block": str(BIN / "asg-vcs-diff-block"),
            "exec_wrapper": str(BIN / "asg-run"),
            "recovery_helper": str(BIN / "asg-recover"),
            "fail_open_helper": str(BIN / "asg-hook-lib"),
            "codex_hook": str(BIN / "asg-codex-hook"),
            "cursor_hooks": {
                "beforeSubmitPrompt": str(BIN / "asg-cursor-before-prompt"),
                "preToolUse": str(BIN / "asg-cursor-pretooluse"),
                "beforeShellExecution": str(BIN / "asg-cursor-before-shell"),
                "beforeMCPExecution": str(BIN / "asg-cursor-before-mcp"),
                "beforeReadFile": str(BIN / "asg-cursor-before-read"),
                "postToolUse": str(BIN / "asg-cursor-posttooluse"),
                "afterShellExecution": str(BIN / "asg-cursor-after-shell"),
                "afterMCPExecution": str(BIN / "asg-cursor-after-mcp"),
                "afterFileEdit": str(BIN / "asg-cursor-after-file-edit"),
                "afterAgentResponse": str(BIN / "asg-cursor-after-agent-response"),
                "afterAgentThought": str(BIN / "asg-cursor-after-agent-thought"),
            },
        },
        "snippets": snippets,
    }
    MANIFEST.write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")
    print(json.dumps(manifest, indent=2, sort_keys=True))
    return 0 if all(item["present"] for item in installed.values()) and core.exists() else 1


if __name__ == "__main__":
    raise SystemExit(main())
